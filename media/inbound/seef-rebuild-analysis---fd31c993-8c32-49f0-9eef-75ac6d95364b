### 9.3 ISC门禁机制详细设计

#### 9.3.1 Check-in（准入检查）

每个子技能执行前必须通过ISC Check-in：

```python
# subskills/base.py
class SubskillBase:
    def __init__(self, isc_client):
        self.isc_client = isc_client
    
    async def execute(self, context):
        # 1. ISC Check-in
        checkin_result = await self.isc_client.checkin({
            'subskill': self.name,
            'skill_id': context['skill_id'],
            'trigger_event': context['trigger_event']
        })
        
        if not checkin_result['allowed']:
            return {
                'exit_status': 'blocked_by_isc',
                'reason': checkin_result['reason'],
                'isc_rule': checkin_result['rule_id']  # e.g., "N036"
            }
        
        # 2. 获取执行参数
        exec_params = checkin_result['params']
        # 例如: { 'threshold': 0.85, 'auto_fix': True, 'max_changes': 10 }
        
        # 3. 执行子技能逻辑
        result = await self._do_execute(context, exec_params)
        
        # 4. ISC Check-out
        checkout_result = await self.isc_client.checkout({
            'subskill': self.name,
            'skill_id': context['skill_id'],
            'result': result
        })
        
        if not checkout_result['valid']:
            return {
                'exit_status': 'rejected_by_isc',
                'reason': checkout_result['reason'],
                'original_result': result
            }
        
        # 5. 反馈到ISC
        await self.isc_client.feedback({
            'subskill': self.name,
            'skill_id': context['skill_id'],
            'metrics': result['metrics'],
            'success': True
        })
        
        return result
```

#### 9.3.2 ISC规则映射

| ISC规则 | 影响的子技能 | 门禁逻辑 |
|---------|-------------|---------|
| **N016** | evaluator | 如技能最近7天内已评估且无变更，返回`allowed=false` |
| **N017** | evaluator | 动态提供阈值参数，如`threshold=0.85` |
| **N036** | optimizer | 如技能标记为"生产关键"，返回`auto_fix=false`，需人工审核 |
| **N042** | creator | 如技能数量超限，返回`allowed=false` |
| **N051** | aligner | 提供最新标准版本号，如`isc_version=3.0.5` |

#### 9.3.3 Check-out（准出验证）

```python
# ISC Gateway 端实现
class ISCGateway:
    async def checkout(self, request):
        subskill = request['subskill']
        result = request['result']
        
        # 验证输出格式
        if not self._validate_schema(result, subskill):
            return {
                'valid': False,
                'reason': 'Invalid output schema'
            }
        
        # 验证业务规则
        if subskill == 'optimizer':
            # 检查修改范围是否超限
            if result.get('changes_count', 0) > self.rules['N036']['max_changes']:
                return {
                    'valid': False,
                    'reason': f"Too many changes: {result['changes_count']}"
                }
        
        if subskill == 'evaluator':
            # 检查评分是否在合理范围
            score = result['metrics'].get('standard_compliance', {}).get('compliance_score', 0)
            if score < 0 or score > 1:
                return {
                    'valid': False,
                    'reason': f"Invalid compliance score: {score}"
                }
        
        return {'valid': True}
```

### 9.4 决策树实现

```javascript
// lib/decision-engine.js
class DecisionEngine {
  constructor(iscClient) {
    this.iscClient = iscClient;
  }
  
  async decide(evaluatorResult, context) {
    const { exit_status, metrics, findings } = evaluatorResult;
    
    // 获取ISC决策规则
    const iscRules = await this.iscClient.getRules(context.skill_id);
    
    // 决策树
    switch (exit_status) {
      case 'skip':
        return {
          subskills: ['recorder'],
          reason: 'No action needed',
          isc_rule: 'N016'
        };
      
      case 'ready_for_next':
        // 检查N036: 是否允许自动优化
        if (iscRules.N036.auto_optimize) {
          return {
            subskills: ['optimizer', 'validator', 'recorder'],
            reason: 'Auto-optimization allowed',
            isc_rule: 'N036'
          };
        } else {
          return {
            subskills: ['recorder'],
            reason: 'Manual review required',
            isc_rule: 'N036',
            notification: {
              type: 'manual_review',
              assignee: 'skill_owner'
            }
          };
        }
      
      case 'need_investigation':
        // 执行discoverer分析根因
        const discovererResult = await this.executeSubskill('discoverer', context);
        
        // 根据discoverer结果决定下一步
        if (discovererResult.root_cause === 'capability_gap') {
          return {
            subskills: ['creator', 'validator', 'recorder'],
            reason: 'Capability gap detected',
            isc_rule: 'N042'
          };
        } else if (discovererResult.root_cause === 'quality_issue') {
          return {
            subskills: ['optimizer', 'validator', 'recorder'],
            reason: 'Quality issue detected',
            isc_rule: 'N036'
          };
        } else if (discovererResult.root_cause === 'standard_drift') {
          return {
            subskills: ['aligner', 'validator', 'recorder'],
            reason: 'Standard drift detected',
            isc_rule: 'N051'
          };
        }
        break;
      
      default:
        throw new Error(`Unknown exit_status: ${exit_status}`);
    }
  }
  
  async executeSubskill(name, context) {
    // 调用Python子技能
    const result = await callPythonSubskill(name, [
      context.skill_path,
      '--context', JSON.stringify(context)
    ]);
    return result;
  }
}
```

### 9.5 反馈闭环实现

#### 9.5.1 更新ISC标准库

```javascript
// lib/isc-client.js
class ISCClient {
  async feedback(data) {
    const { subskill, skill_id, metrics, success } = data;
    
    // 1. 记录执行历史
    await this.api.post('/feedback/execution', {
      subskill,
      skill_id,
      timestamp: Date.now(),
      success,
      metrics
    });
    
    // 2. 更新质量趋势
    const trend = await this.api.get(`/trends/${skill_id}`);
    const newTrend = this._calculateTrend(trend, metrics);
    
    // 3. 动态调整阈值
    if (newTrend.consecutive_passes >= 10) {
      // 连续10次通过，提高阈值
      await this.api.patch(`/rules/N017/${skill_id}`, {
        threshold: Math.min(newTrend.current_threshold + 0.05, 0.95)
      });
    }
    
    // 4. 识别新的反模式
    if (metrics.findings) {
      const patterns = this._extractPatterns(metrics.findings);
      await this.api.post('/patterns/report', {
        skill_id,
        patterns,
        source: subskill
      });
    }
  }
}
```

