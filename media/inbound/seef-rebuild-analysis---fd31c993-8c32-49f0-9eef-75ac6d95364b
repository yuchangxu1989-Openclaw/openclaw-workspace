    const newSuccessRate = this._calculateSuccessRate(stats, execution_result);
    
    // 3. 关联用户痛点
    if (user_feedback && user_feedback.pain_points) {
      await this.api.post('/insights/pain_points', {
        skill_id,
        pain_points: user_feedback.pain_points,
        resolved: execution_result.success,
        resolution_method: execution_result.method
      });
    }
    
    // 4. 生成洞察报告
    if (newSuccessRate < 0.8) {
      await this.api.post('/insights/alert', {
        skill_id,
        type: 'low_success_rate',
        current_rate: newSuccessRate,
        threshold: 0.8,
        recommendation: 'Consider re-evaluation or optimization'
      });
    }
  }
}
