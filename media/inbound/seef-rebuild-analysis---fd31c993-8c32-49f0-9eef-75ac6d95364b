// lib/dto-adapter.js
class DTOAdapter {
  async sendFeedback(event) {
    const { type, skill_id, result } = event;
    
    switch (type) {
      case 'validation_failed':
        // 触发DTO修复流程
        await this.dto.publish('skill.validation_failed', {
          skill_id,
          failures: result.failures,
          suggested_fixes: result.suggested_fixes,
          priority: 'high'
        });
        break;
      
      case 'optimization_completed':
        // 通知DTO优化完成
        await this.dto.publish('skill.optimized', {
          skill_id,
          changes: result.changes,
          improvements: result.improvements,
          new_version: result.new_version
        });
        break;
      
      case 'capability_gap_detected':
        // 触发新技能创建流程
        await this.dto.publish('skill.gap_detected', {
          gap_description: result.gap_description,
          suggested_skill_name: result.suggested_name,
          priority: result.priority
        });
        break;
    }
  }
}
