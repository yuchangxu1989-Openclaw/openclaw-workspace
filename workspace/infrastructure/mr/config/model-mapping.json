{
  "_description": "MR模型占位符到实际模型的映射配置",
  "_version": "1.0.0",
  "_update_policy": "通过CapabilityAnchor动态更新",
  
  "models": {
    "{{MODEL_GENERAL}}": {
      "primary": "claude/claude-sonnet-4-6",
      "fallbacks": ["zhipu/glm-4.7", "zhipu/glm-4-flash"],
      "description": "通用对话模型，快速响应"
    },
    "{{MODEL_DEEP_THINKING}}": {
      "primary": "zhipu/glm-5",
      "fallbacks": ["zhipu/glm-thinking", "claude/claude-sonnet-4-6"],
      "description": "深度思考模型，复杂推理"
    },
    "{{MODEL_VISION}}": {
      "primary": "zhipu/glm-4v-plus",
      "fallbacks": ["zhipu/glm-4v", "zhipu/glm-ocr"],
      "description": "视觉理解模型，图像分析"
    },
    "{{MODEL_AUDIO}}": {
      "primary": "zhipu/glm-asr",
      "fallbacks": ["zhipu/glm-4v"],
      "description": "音频处理模型，语音识别"
    },
    "{{MODEL_CODE_REVIEW}}": {
      "primary": "zhipu/glm-5-coder",
      "fallbacks": ["zhipu/glm-5", "claude/claude-sonnet-4-6"],
      "description": "代码审查模型，Bug检测"
    }
  },
  
  "resolution": {
    "description": "占位符解析规则",
    "mode": "static_mapping",
    "cache_ttl": 300,
    "fallback_on_failure": true
  }
}
