      "args": [
        "user-insight"
      ],
      "schedule": "*/30 * * * *",
      "schedule_human": "每30分钟",
      "model": "zhipu/glm-5",
      "enabled": true,
      "trigger": "event_bridge",
      "trigger_condition": "兜底: 30分钟内无cras.insight.generated事件",
      "mode": "event_driven_with_fallback",
      "primary_channel": "eventbus",
      "primary_event": "cras.insight.request",
      "outputs": [
        "infrastructure/logs/fallback-sweep.jsonl"
      ],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": [
        "event-driven",
        "fallback-sweep",
        "user-insight",
        "day3-gap2"
      ],
      "created": "2026-03-06",
      "bridge_event": "cron.job.requested",
      "bridge_runner": "infrastructure/event-bus/cron-event-bridge-runner.js",
      "execution_mode": "event_driven_with_fallback",
      "time_schedule": "*/30 * * * *"
    },
    {
      "name": "system-health-l3",
      "description": "[Day3-Gap2] 系统健康检查L3扩展版 — 含EventBus/Pipeline/Decision/FeatureFlag指标",
      "script": "infrastructure/cron/fallback-sweep.js",
      "args": [
        "health",
