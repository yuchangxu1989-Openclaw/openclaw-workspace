      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": [
        "event-driven",
        "health-check",
        "l3-metrics",
        "day3-gap2"
      ],
      "created": "2026-03-06",
      "bridge_event": "cron.job.requested",
      "bridge_runner": "infrastructure/event-bus/cron-event-bridge-runner.js",
      "execution_mode": "event_driven_with_fallback",
      "time_schedule": "0 * * * *"
    },
    {
      "name": "pipeline-dashboard-full",
      "description": "[Day2-Gap2] 五层闭环运营仪表盘 — 采集认知-决策-执行-效果-系统全链路指标，生成Agent运营视角报告",
      "script": "infrastructure/observability/pipeline-dashboard-cron.js",
