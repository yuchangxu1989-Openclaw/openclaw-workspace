{
  "_schema": "cron-jobs-v2",
  "_description": "OpenClaw workspace cron job registry",
  "_updated": "2026-03-06",
  "_doc": "Job model field required per ISC rule.cron-task-model-requirement-001 (zhipu/glm-5 preferred)",
  "jobs": [
    {
      "name": "day-completion-scanner",
      "description": "Day完成事件检测器 - 自动扫描设计债务（每小时检查一次）",
      "script": "infrastructure/self-check/day-completion-scanner.js",
      "args": ["--auto"],
      "schedule": "0 * * * *",
      "schedule_human": "每小时整点",
      "model": "zhipu/glm-5",
      "model_fallback": "claude/claude-sonnet-4-6",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "reports/dayN-closure-conditions.md 文件新增",
      "outputs": ["reports/auto-debt-scan-dayN.md"],
      "timeout_seconds": 120,
      "on_failure": "log_and_continue",
      "tags": ["self-check", "debt-scan", "day-completion"],
      "created": "2026-03-05"
    },
    {
      "name": "rework-analyzer",
      "description": "返工根因分析器 - 检测子Agent steer/重启事件，分析根因（每5分钟）",
      "script": "infrastructure/self-check/rework-analyzer.js",
      "args": ["--auto"],
      "schedule": "*/5 * * * *",
      "schedule_human": "每5分钟",
      "model": "zhipu/glm-5",
      "model_fallback": "claude/claude-sonnet-4-6",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "subagent日志中出现steer/restart/kill信号",
      "outputs": [
        "infrastructure/aeo/golden-testset/self-awareness-cases.json (append)",
        "skills/isc-core/rules/_drafts/draft.rework-*.json",
        "reports/rework-analysis-YYYY-MM-DD.md"
      ],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": ["self-check", "rework", "root-cause", "isc"],
      "created": "2026-03-05"
    },
    {
      "name": "correction-harvester",
      "description": "用户纠偏收割器 - 检测纠偏信号，抽象规则草案（每5分钟）",
      "script": "infrastructure/self-check/correction-harvester.js",
      "args": ["--auto"],
      "schedule": "*/5 * * * *",
      "schedule_human": "每5分钟",
      "model": "zhipu/glm-5",
      "model_fallback": "claude/claude-sonnet-4-6",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "记忆文件中出现纠偏信号关键词",
      "outputs": [
        "infrastructure/aeo/golden-testset/pending-cases.json",
        "reports/correction-harvest-YYYY-MM-DD.md"
      ],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": ["self-check", "correction", "golden-testset", "rule-draft"],
      "created": "2026-03-05"
    },
    {
      "name": "auto-response-sweep",
      "description": "[Day3-Gap2] 自动响应管道兜底补扫 — 检查EventBus中遗漏的evolver/cras事件",
      "script": "infrastructure/cron/fallback-sweep.js",
      "args": ["auto-response"],
      "schedule": "*/15 * * * *",
      "schedule_human": "每15分钟",
      "model": "zhipu/glm-5",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "兜底: EventBus中有未处理的evolver.insight.detected等事件",
      "mode": "event_driven_with_fallback",
      "primary_channel": "eventbus",
      "outputs": ["infrastructure/logs/fallback-sweep.jsonl"],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": ["event-driven", "fallback-sweep", "auto-response", "day3-gap2"],
      "created": "2026-03-06"
    },
    {
      "name": "user-insight-sweep",
      "description": "[Day3-Gap2] CRAS用户洞察兜底补扫 — 检查30分钟内是否有洞察输出",
      "script": "infrastructure/cron/fallback-sweep.js",
      "args": ["user-insight"],
      "schedule": "*/30 * * * *",
      "schedule_human": "每30分钟",
      "model": "zhipu/glm-5",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "兜底: 30分钟内无cras.insight.generated事件",
      "mode": "event_driven_with_fallback",
      "primary_channel": "eventbus",
      "primary_event": "cras.insight.request",
      "outputs": ["infrastructure/logs/fallback-sweep.jsonl"],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": ["event-driven", "fallback-sweep", "user-insight", "day3-gap2"],
      "created": "2026-03-06"
    },
    {
      "name": "system-health-l3",
      "description": "[Day3-Gap2] 系统健康检查L3扩展版 — 含EventBus/Pipeline/Decision/FeatureFlag指标",
      "script": "infrastructure/cron/fallback-sweep.js",
      "args": ["health"],
      "schedule": "0 * * * *",
      "schedule_human": "每小时整点",
      "model": "zhipu/glm-5",
      "enabled": true,
      "trigger": "time",
      "trigger_condition": "定时 + 事件驱动兜底",
      "mode": "event_driven_with_fallback",
      "primary_channel": "eventbus",
      "primary_event": "system.health.request",
      "outputs": ["infrastructure/logs/fallback-sweep.jsonl", "infrastructure/logs/health.jsonl"],
      "timeout_seconds": 60,
      "on_failure": "log_and_continue",
      "tags": ["event-driven", "health-check", "l3-metrics", "day3-gap2"],
      "created": "2026-03-06"
    }
  ],
  "_cron_install_hint": "在系统crontab中安装方式:\n  0 * * * *   cd /root/.openclaw/workspace && node infrastructure/self-check/day-completion-scanner.js --auto >> infrastructure/logs/day-scanner.log 2>&1\n  */5 * * * * cd /root/.openclaw/workspace && node infrastructure/self-check/rework-analyzer.js --auto >> infrastructure/logs/rework-analyzer.log 2>&1\n  */5 * * * * cd /root/.openclaw/workspace && node infrastructure/self-check/correction-harvester.js --auto >> infrastructure/logs/correction-harvester.log 2>&1"
}
