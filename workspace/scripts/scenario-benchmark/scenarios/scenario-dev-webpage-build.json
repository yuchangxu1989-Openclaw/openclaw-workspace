{
  "id": "scenario-dev-webpage-build",
  "name": "网页制作全链路",
  "domain": "development",
  "description": "从需求到网页交付的完整流程",
  "steps": [
    { "action": "emit", "event": "user.message", "payload": { "text": "帮我做一个产品展示页面，要有hero区域、功能介绍、价格对比和联系表单，风格要现代简洁" } },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
