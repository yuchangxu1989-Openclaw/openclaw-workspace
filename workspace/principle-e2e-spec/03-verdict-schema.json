{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "p2e-verdict.schema.json",
  "title": "P2E Evaluation Verdict",
  "description": "言出法随E2E评测结论结构",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "verdict_id",
    "run_id",
    "case_id",
    "verdict",
    "p2e_score",
    "stage_results",
    "hard_gate_failures",
    "created_at"
  ],
  "properties": {
    "verdict_id": {
      "type": "string",
      "description": "评测结论唯一ID",
      "pattern": "^verdict-[a-z0-9]{8,}$",
      "example": "verdict-a1b2c3d4"
    },
    "run_id": {
      "type": "string",
      "description": "本次评测运行ID（一次run可含多个case）",
      "example": "run-20260307-001"
    },
    "case_id": {
      "type": "string",
      "description": "测试用例ID",
      "example": "p2e-tc-001"
    },
    "verdict": {
      "type": "string",
      "enum": ["SUCCESS", "PARTIAL", "FAIL", "SKIP"],
      "description": "最终评测结论"
    },
    "p2e_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "加权综合评分 [0,1]"
    },
    "hard_gate_failures": {
      "type": "integer",
      "minimum": 0,
      "description": "HARD Gate失败数量，任何>0均导致FAIL"
    },
    "skip_reason": {
      "type": "string",
      "description": "当verdict=SKIP时的跳过原因",
      "enum": [
        "NON_P2E_INTENT",
        "BELOW_CONFIDENCE_THRESHOLD",
        "MANUAL_SKIP"
      ]
    },
    "stage_results": {
      "type": "array",
      "description": "各阶段评测结果",
      "items": {
        "$ref": "#/definitions/StageResult"
      }
    },
    "intent_summary": {
      "type": "object",
      "description": "被评测意图的摘要",
      "properties": {
        "raw_text": { "type": "string" },
        "detected_type": {
          "type": "string",
          "enum": ["PRINCIPLE", "VERDICT", "CONSTRAINT", "GOAL", "DIRECTIVE", "UNKNOWN"]
        },
        "target": { "type": "string" },
        "scope": { "type": "string" }
      }
    },
    "release_decision": {
      "type": "object",
      "description": "发布决策",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["RELEASE", "PARTIAL_RELEASE", "BLOCK", "SKIP"]
        },
        "version": { "type": "string" },
        "rollback_version": { "type": "string" }
      }
    },
    "duration_ms": {
      "type": "integer",
      "description": "全链路耗时（毫秒）"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "评测时间"
    },
    "metadata": {
      "type": "object",
      "description": "附加元数据",
      "properties": {
        "runner_version": { "type": "string" },
        "spec_version": { "type": "string" },
        "environment": {
          "type": "string",
          "enum": ["dev", "staging", "prod"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "StageResult": {
      "type": "object",
      "required": ["stage_id", "stage_name", "verdict", "score", "checks", "duration_ms"],
      "properties": {
        "stage_id": {
          "type": "string",
          "description": "阶段ID",
          "enum": ["intent", "event", "isc", "dto", "cras", "aeo", "lep", "test", "gate", "release"]
        },
        "stage_name": { "type": "string" },
        "verdict": {
          "type": "string",
          "enum": ["PASS", "FAIL", "PARTIAL", "SKIP", "ADVISORY"]
        },
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "weighted_contribution": {
          "type": "number",
          "description": "该阶段对总分的贡献值"
        },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/definitions/CheckResult" }
        },
        "duration_ms": { "type": "integer" },
        "artifacts": {
          "type": "object",
          "description": "该阶段产出的关键产物",
          "additionalProperties": true
        },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "stack": { "type": "string" }
          }
        }
      }
    },
    "CheckResult": {
      "type": "object",
      "required": ["check_id", "passed", "actual_value"],
      "properties": {
        "check_id": { "type": "string" },
        "description": { "type": "string" },
        "gate_type": {
          "type": "string",
          "enum": ["HARD", "SOFT", "ADVISORY"]
        },
        "passed": { "type": "boolean" },
        "actual_value": {},
        "threshold": {},
        "metric": { "type": "string" },
        "details": { "type": "string" }
      }
    }
  },
  "examples": [
    {
      "verdict_id": "verdict-a1b2c3d4",
      "run_id": "run-20260307-001",
      "case_id": "p2e-tc-003",
      "verdict": "SUCCESS",
      "p2e_score": 0.92,
      "hard_gate_failures": 0,
      "intent_summary": {
        "raw_text": "LLM调用失败率超10%必须自动告警",
        "detected_type": "CONSTRAINT",
        "target": "LLM调用失败率",
        "scope": "system-wide"
      },
      "stage_results": [
        {
          "stage_id": "intent",
          "stage_name": "INTENT 意图理解",
          "verdict": "PASS",
          "score": 1.0,
          "weighted_contribution": 0.20,
          "checks": [
            {
              "check_id": "intent.type_classification",
              "gate_type": "HARD",
              "passed": true,
              "actual_value": "CONSTRAINT",
              "threshold": 0.9,
              "metric": "classification_accuracy"
            }
          ],
          "duration_ms": 320
        }
      ],
      "release_decision": {
        "action": "RELEASE",
        "version": "1.0.1"
      },
      "duration_ms": 18500,
      "created_at": "2026-03-07T10:30:00+08:00",
      "metadata": {
        "runner_version": "1.0.0",
        "spec_version": "1.0.0",
        "environment": "staging"
      }
    }
  ]
}
