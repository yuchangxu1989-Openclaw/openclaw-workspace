{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "p2e-capability-runtime.schema.json",
  "title": "P2E Capability Runtime",
  "type": "object",
  "required": [
    "attestation",
    "evidence_bundle",
    "allowlist",
    "denylist",
    "runtime_inputs",
    "blocked_source_hits",
    "redaction",
    "audit",
    "capability_outputs"
  ],
  "properties": {
    "capability_outputs": {
      "type": "object",
      "properties": {
        "intent_expansion": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "content"],
            "properties": {
              "kind": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "event_completion": {
          "type": "object",
          "additionalProperties": true
        },
        "task_expansion": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "title"],
            "properties": {
              "kind": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
