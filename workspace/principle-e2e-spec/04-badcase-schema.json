{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "p2e-badcase.schema.json",
  "title": "P2E Badcase",
  "description": "言出法随E2E评测 Badcase 结构定义",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "badcase_id",
    "run_id",
    "case_id",
    "category",
    "subcategory",
    "failing_stage",
    "failing_check",
    "severity",
    "description",
    "root_cause",
    "created_at"
  ],
  "properties": {
    "badcase_id": {
      "type": "string",
      "description": "Badcase唯一ID",
      "pattern": "^bc-[a-z0-9]{8,}$"
    },
    "run_id": { "type": "string" },
    "case_id": { "type": "string" },
    "category": {
      "type": "string",
      "description": "一级分类",
      "enum": [
        "BC-INTENT",
        "BC-ISC",
        "BC-DTO",
        "BC-LEP",
        "BC-AEO",
        "BC-SILENT",
        "BC-PERF",
        "BC-REGRESSION"
      ]
    },
    "subcategory": {
      "type": "string",
      "description": "二级分类",
      "enum": [
        "INTENT.MISSED",
        "INTENT.WRONG_TYPE",
        "INTENT.PARTIAL_EXTRACT",
        "INTENT.FALSE_POSITIVE",
        "ISC.EMPTY_DRAFT",
        "ISC.SEMANTIC_DEVIATION",
        "ISC.CONFLICT_MISSED",
        "ISC.INVALID_ID_FORMAT",
        "ISC.MISSING_LINEAGE",
        "DTO.DAG_CYCLE",
        "DTO.WRONG_TRIGGER",
        "DTO.MISSING_FALLBACK",
        "DTO.NO_AUTO_SUBSCRIPTION",
        "LEP.UNHANDLED_FAILURE",
        "LEP.MISSING_EXEC_ID",
        "LEP.WAL_INCOMPLETE",
        "LEP.NO_RETRY",
        "AEO.WRONG_TRACK",
        "AEO.INCOMPLETE_COVERAGE",
        "AEO.MISALIGNED_CRITERIA",
        "SILENT.NO_LOG",
        "SILENT.NO_RESULT",
        "SILENT.TIMEOUT_WITHOUT_ERROR",
        "PERF.LATENCY_EXCEEDED",
        "PERF.RESOURCE_EXHAUSTION",
        "REGRESSION.EXISTING_RULE_BROKEN",
        "REGRESSION.CONFLICT_NOT_DETECTED"
      ]
    },
    "failing_stage": {
      "type": "string",
      "enum": ["intent", "event", "isc", "dto", "cras", "aeo", "lep", "test", "gate", "release"]
    },
    "failing_check": {
      "type": "string",
      "description": "失败的具体检查项ID，如 intent.type_classification"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
      "description": "严重程度"
    },
    "description": {
      "type": "string",
      "description": "问题描述（人类可读）"
    },
    "input_utterance": {
      "type": "string",
      "description": "触发Badcase的原始用户输入"
    },
    "expected_behavior": {
      "type": "string",
      "description": "预期正确行为"
    },
    "actual_behavior": {
      "type": "string",
      "description": "实际错误行为"
    },
    "root_cause": {
      "type": "object",
      "required": ["hypothesis", "confidence"],
      "properties": {
        "hypothesis": {
          "type": "string",
          "description": "根因假说"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "归因置信度"
        },
        "component": {
          "type": "string",
          "description": "问题所在组件"
        },
        "traceback": {
          "type": "array",
          "items": { "type": "string" },
          "description": "调用栈或执行链回溯"
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "user_visible": {
          "type": "boolean",
          "description": "用户是否感知到问题"
        },
        "data_corrupted": {
          "type": "boolean",
          "description": "是否导致数据损坏"
        },
        "system_state_dirty": {
          "type": "boolean",
          "description": "是否污染系统状态（如ISC规则库）"
        },
        "affected_rules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "受影响的规则ID列表"
        }
      }
    },
    "fix_suggestion": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "FIX_PROMPT",
            "FIX_SCHEMA",
            "FIX_ROUTING",
            "ADD_TEST_CASE",
            "UPDATE_THRESHOLD",
            "INVESTIGATE",
            "ACCEPT_AS_LIMITATION"
          ]
        },
        "detail": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"]
        }
      }
    },
    "linked_verdict_id": {
      "type": "string",
      "description": "关联的评测结论ID"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "修复时间（如已修复）"
    },
    "status": {
      "type": "string",
      "enum": ["OPEN", "IN_PROGRESS", "RESOLVED", "WONT_FIX"],
      "default": "OPEN"
    }
  },
  "examples": [
    {
      "badcase_id": "bc-f1a2b3c4",
      "run_id": "run-20260307-001",
      "case_id": "p2e-tc-007",
      "category": "BC-INTENT",
      "subcategory": "INTENT.WRONG_TYPE",
      "failing_stage": "intent",
      "failing_check": "intent.type_classification",
      "severity": "HIGH",
      "description": "用户表达'所有技能必须有测试'被识别为DIRECTIVE而非PRINCIPLE",
      "input_utterance": "所有技能文件修改后都应该自动跑一遍lint检查",
      "expected_behavior": "识别为 PRINCIPLE，触发ISC规则生成流程",
      "actual_behavior": "识别为 DIRECTIVE，直接尝试执行lint命令",
      "root_cause": {
        "hypothesis": "意图分类器缺乏'应该/必须+自动化'模式的训练样本",
        "confidence": 0.85,
        "component": "intent-classifier",
        "traceback": ["cras/index.js:classify_intent", "isc-core/intent-parser.js:infer_type"]
      },
      "impact": {
        "user_visible": true,
        "data_corrupted": false,
        "system_state_dirty": false,
        "affected_rules": []
      },
      "fix_suggestion": {
        "action": "ADD_TEST_CASE",
        "detail": "在意图分类训练集中增加'应该/必须+长期/自动'模式的PRINCIPLE样本",
        "priority": "P1"
      },
      "linked_verdict_id": "verdict-z9y8x7w6",
      "created_at": "2026-03-07T10:35:00+08:00",
      "status": "OPEN"
    },
    {
      "badcase_id": "bc-a4b5c6d7",
      "run_id": "run-20260307-001",
      "case_id": "p2e-tc-012",
      "category": "BC-SILENT",
      "subcategory": "SILENT.NO_RESULT",
      "failing_stage": "isc",
      "failing_check": "isc.draft_generation",
      "severity": "CRITICAL",
      "description": "ISC收到VERDICT类事件后无任何响应，无日志无错误无规则生成",
      "input_utterance": "议会决定：所有对外API调用必须经过速率限制",
      "expected_behavior": "ISC生成速率限制相关规则草案",
      "actual_behavior": "ISC静默，没有生成任何产物，也没有报错",
      "root_cause": {
        "hypothesis": "VERDICT类事件的事件路由配置缺失，ISC未订阅该事件类型",
        "confidence": 0.90,
        "component": "event-bus-routing",
        "traceback": ["dto-core/event-bridge.js:route", "isc-core/event-bridge.js:subscribe"]
      },
      "impact": {
        "user_visible": false,
        "data_corrupted": false,
        "system_state_dirty": false,
        "affected_rules": []
      },
      "fix_suggestion": {
        "action": "FIX_ROUTING",
        "detail": "在ISC事件订阅配置中增加 isc.verdict.received 事件类型",
        "priority": "P0"
      },
      "linked_verdict_id": "verdict-m1n2o3p4",
      "created_at": "2026-03-07T11:00:00+08:00",
      "status": "OPEN"
    }
  ]
}
