{
  "id": "cras-b-user-insight",
  "intent": "CRAS-B 用户洞察分析 - 每30分钟执行",
  "version": "1.1.0",
  "_reshaped": {
    "status": "RESHAPED",
    "note": "Day3-Gap2: 主路径迁移到 EventBus 事件驱动 (cras.insight.request → Dispatcher → skill-cras-handler)。本文件保留为向后兼容参考。新配置: skills/dto-core/config/cron/cras-b-user-insight.json",
    "reshaped_at": "2026-03-06"
  },
  "model": "claude/claude-opus-4-6-thinking",
  "triggers": [
    {
      "type": "cron",
      "spec": "*/30 * * * *",
      "timezone": "Asia/Shanghai"
    }
  ],
  "constraints": [
    {
      "standard": "cras.user_insight.enabled",
      "operator": "required",
      "severity": "warning"
    }
  ],
  "timeout": {
    "total_seconds": 120,
    "per_action_seconds": 60
  },
  "retry": {
    "max_attempts": 2,
    "backoff": "exponential",
    "delay_seconds": 10
  },
  "actions": [
    {
      "type": "module",
      "module": "cras",
      "skill": "user-insight-hub",
      "action": "analyze",
      "params": {
        "format": "feishu_card",
        "include_todos": true,
        "persist_profile": true
      },
      "timeout": 60
    },
    {
      "type": "notify",
      "channel": "feishu",
      "message": "CRAS-B 用户洞察分析完成",
      "delivery": {
        "queue": true,
        "retry": {
          "max_attempts": 3,
          "delay_seconds": 5
        }
      }
    }
  ],
  "error_handling": {
    "on_timeout": {
      "action": "notify_failure",
      "channel": "feishu",
      "message": "⚠️ CRAS-B 用户洞察分析执行超时"
    },
    "on_error": {
      "action": "retry_then_escalate",
      "max_retries": 2
    }
  },
  "metadata": {
    "author": "system",
    "priority": "medium",
    "category": "insight",
    "description": "每30分钟执行用户洞察分析，生成飞书卡片报告"
  }
}