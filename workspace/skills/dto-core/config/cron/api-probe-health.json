{
  "name": "api-probe-health",
  "schedule": "*/5 * * * *",
  "command": "cd /root/.openclaw/workspace && node /root/.openclaw/workspace/scripts/api-probe.js >> /tmp/api-probe.log 2>&1",
  "workingDirectory": "/root/.openclaw/workspace",
  "timezone": "Asia/Shanghai",
  "enabled": true,
  "onFailure": {
    "type": "feishu",
    "message": "[api-probe-health] API probe failed on $(hostname) at $(date -Iseconds). Please check /tmp/api-probe.log"
  }
}
