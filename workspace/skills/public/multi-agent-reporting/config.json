{
  "requiredFields": ["agentId", "model", "task", "status"],
  "optionalFields": [
    "duration",
    "commit",
    "thinking",
    "error",
    "blocker",
    "decision",
    "decisionOwner",
    "nextAction",
    "nextOwner",
    "nextETA",
    "handoffTo",
    "artifact",
    "branch",
    "updatedAt"
  ],
  "statusIcons": {
    "completed": "✅",
    "running": "🔄",
    "failed": "❌",
    "blocked": "⏸️",
    "pending": "⏳",
    "needs_decision": "⚖️",
    "waiting": "🕒",
    "cancelled": "🚫"
  },
  "outputFormat": "table",
  "showThinking": true,
  "showSummary": true,
  "showNextSteps": true,
  "showDashboard": true,
  "showStatusSections": true,
  "showModelBreakdown": true,
  "showNextHop": true,
  "showDecisions": true,
  "showTaskIds": true,
  "title": "Multi-Agent Progress Report",
  "sectionTitles": {
    "overview": "Overview",
    "running": "Running",
    "completed": "Completed",
    "blocked": "Blocked",
    "needsDecision": "Needs Decision",
    "nextActions": "Next Actions",
    "modelBreakdown": "Model Breakdown",
    "detailedBoard": "Detailed Board"
  },
  "statusGroups": {
    "running": ["running"],
    "completed": ["completed"],
    "blocked": ["blocked", "failed"],
    "needsDecision": ["needs_decision"]
  },
  "validation": {
    "requireCommitOnComplete": true,
    "requireErrorOnFail": true,
    "requireFullModelName": true,
    "modelNameMinLength": 8,
    "knownModelPrefixes": [
      "claude-", "gpt-", "gemini-", "llama-", "mistral-", "command-",
      "deepseek-", "qwen-", "yi-", "phi-", "o1-", "o3-", "o4-"
    ],
    "shortNameBlacklist": [
      "claude", "gpt", "gpt4", "gpt-4", "sonnet", "opus", "haiku",
      "gemini", "llama", "mistral", "deepseek", "qwen"
    ],
    "requireNextActionOnActive": false,
    "requireDecisionOwnerOnNeedsDecision": false,
    "requireBlockerOnBlocked": false
  }
}
