{
  "eval_standard_schema": "infrastructure/aeo/eval-standard-schema.json",
  "eval_standard_config": "skills/isc-core/config/eval-standard-version.json",
  "_note": "quality_rules synced from eval-standard-schema.json — schema is the single source of truth",
  "batch_size": 10,
  "max_cases_per_task": 10,
  "hard_limit": true,
  "lines_per_batch": 500,
  "standard_doc_note": "doc_token已迁移至 skills/isc-core/config/eval-standard-version.json",
  "output_dir": "tests/benchmarks/intent/c2-golden/",
  "max_concurrent": 16,
  "golden_case_reference": "tests/benchmarks/intent/c2-golden/00-real-badcases.json",
  "auto_sync_on_standard_change": true,
  "standard_version_cache": "skills/public/eval-mining/.eval-standard-version-hash",
  "quality_rules": {
    "required_fields": ["id", "input", "expected_output", "category", "difficulty", "source"],
    "c2_requirements": {
      "multi_turn": true,
      "min_input_length": 20,
      "source": "real_conversation",
      "min_execution_steps": 4
    },
    "valid_categories": ["纠偏类", "认知错误类", "全局未对齐类", "头痛医头类", "反复未果类", "连锁跷跷板类", "自主性缺失类", "交付质量类"],
    "valid_difficulties": ["C1", "C2"]
  }
}
