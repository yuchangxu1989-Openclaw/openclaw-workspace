{
  "subscription_id": "sub-vectorization-aeo-created",
  "subscriber": "vectorization-service",
  "event_type": "aeo.evaluation_set.created",
  "description": "AEO评测用例创建时自动触发向量化",
  "condition": {
    "file_pattern": "aeo/evaluation-sets/**/*.json",
    "action": "created"
  },
  "handler": {
    "type": "exec",
    "command": "/root/.openclaw/workspace/infrastructure/vector-service/vectorize.sh",
    "async": true,
    "timeout_seconds": 300
  },
  "priority": 6,
  "auto_execute": true,
  "created_at": "2026-02-28T23:30:00+08:00",
  "metadata": {
    "trigger_source": "dto-event",
    "target_types": ["aeo"],
    "vector_engine": "zhipu-embedding-3"
  }
}
