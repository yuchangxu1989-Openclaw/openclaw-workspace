{
  "id": "seef-skill-registered",
  "name": "SEEF技能注册触发器",
  "description": "监听技能注册和更新事件，自动触发SEEF Evaluator进行质量评估",
  "version": "1.0.0",
  "enabled": true,
  "events": [
    "skill.registered",
    "skill.updated"
  ],
  "handler": {
    "type": "skill",
    "skill": "seef",
    "subskill": "evaluator",
    "input": {
      "skillId": "{{event.payload.skillId}}",
      "skillPath": "{{event.payload.skillPath}}",
      "skillName": "{{event.payload.skillName}}",
      "version": "{{event.payload.version}}",
      "trigger": "dto",
      "timestamp": "{{event.timestamp}}"
    }
  },
  "filters": {
    "excludeSkills": [
      "lto-core",
      "isc-core",
      "seef"
    ],
    "minVersion": "0.0.1"
  },
  "priority": "high",
  "metadata": {
    "created_at": "2026-03-01T11:33:00Z",
    "created_by": "seef-p0-implementation",
    "purpose": "P0阶段：打通DTO事件→Evaluator基础链路"
  }
}
