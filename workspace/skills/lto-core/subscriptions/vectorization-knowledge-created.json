{
  "subscription_id": "sub-vectorization-knowledge-created",
  "subscriber": "vectorization-service",
  "event_type": "knowledge.created",
  "description": "知识文件创建时自动触发向量化",
  "condition": {
    "file_pattern": "knowledge/*.json",
    "action": "created"
  },
  "handler": {
    "type": "exec",
    "command": "/root/.openclaw/workspace/infrastructure/vector-service/vectorize.sh",
    "async": true,
    "timeout_seconds": 300
  },
  "priority": 7,
  "auto_execute": true,
  "created_at": "2026-02-28T23:30:00+08:00",
  "metadata": {
    "trigger_source": "lto-event",
    "target_types": ["knowledge"],
    "vector_engine": "zhipu-embedding-3"
  }
}
