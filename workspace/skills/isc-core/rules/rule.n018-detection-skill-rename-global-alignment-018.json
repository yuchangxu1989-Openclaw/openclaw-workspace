{
    "id": "rule.n018-detection-skill-rename-global-alignment-018",
    "event_type": "skill_renamed",
    "name": "skill_rename_global_reference_alignment",
    "description": "技能重命名全局引用对齐 - 检测到技能/模块重命名或移动时，自动扫描并更新所有引用点",
    "type": "detection",
    "domain": "architecture",
    "scope": "system-wide",
    "trigger": {
        "events": [
            "skill_renamed",
            "skill_moved",
            "module_refactored"
        ],
        "detection_method": "file_system_watcher",
        "actions": [
            {
                "type": "auto_trigger",
                "description": "技能重命名后自动扫描全局引用并执行对齐更新"
            }
        ],
        "event": "skill_renamed"
    },
    "governance": {
        "auto_execute": true,
        "priority": "HIGH",
        "risk_level": "high",
        "requires_backup": true
    },
    "scan_targets": [
        {
            "type": "cron_jobs",
            "location": ".openclaw/cron/jobs.json",
            "scan_pattern": "command|script_path"
        },
        {
            "type": "dto_subscriptions",
            "location": "skills/lto-core/subscriptions/",
            "scan_pattern": "rule_id|file_reference"
        },
        {
            "type": "isc_rules",
            "location": "skills/isc-core/rules/",
            "scan_pattern": "references|dependencies"
        },
        {
            "type": "skill_imports",
            "location": "skills/**/index.js",
            "scan_pattern": "require|import"
        },
        {
            "type": "documentation",
            "location": "**/*.md",
            "scan_pattern": "skill_name|file_path"
        },
        {
            "type": "capability_anchor",
            "location": "CAPABILITY-ANCHOR.md",
            "scan_pattern": "skill_reference"
        }
    ],
    "execution": {
        "type": "phased_update",
        "phases": [
            {
                "phase": 1,
                "name": "scan_and_identify",
                "action": "scan_all_targets",
                "output": "affected_references_list"
            },
            {
                "phase": 2,
                "name": "backup",
                "action": "create_backup",
                "target": "all_files_to_modify"
            },
            {
                "phase": 3,
                "name": "update_references",
                "action": "batch_update",
                "order": [
                    "cron_jobs",
                    "dto_subscriptions",
                    "isc_rules",
                    "skill_imports",
                    "documentation",
                    "capability_anchor"
                ],
                "verification_each": true
            },
            {
                "phase": 4,
                "name": "verify_integrity",
                "action": "run_integrity_checks",
                "checks": [
                    "no_broken_cron_references",
                    "no_import_errors",
                    "dto_subscriptions_aligned",
                    "isc_dto_handshake_pass"
                ]
            }
        ],
        "rollback_on_failure": true
    },
    "notification": {
        "on_detection": {
            "channel": "feishu",
            "format": "compact",
            "content": "检测到技能重命名: {old_name} → {new_name}，开始全局引用对齐"
        },
        "on_complete": {
            "content": "全局引用对齐完成，更新{affected_count}处引用"
        },
        "on_failure": {
            "level": "critical",
            "content": "全局对齐失败，已回滚到备份状态，需人工检查"
        }
    },
    "created_at": "2026-02-25T23:45:00Z",
    "updated_at": "2026-02-25T23:46:46+08:00",
    "version": "1.0.0",
    "status": "active",
    "enforcement_tier": "P1_process",
    "action": {
        "type": "script",
        "handler": "naming-convention-check",
        "script": "scripts/isc-hooks/rule.n018-detection-skill-rename-global-alignment-018.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/n018-detection-skill-rename-global-alignment.js",
    "verification": {
        "method": "convention_compliance_check",
        "description": "验证规范规则 rule.n018-detection-skill-rename-global-alignment-018 的一致性检查",
        "assertions": [
            {
                "check": "naming_pattern_enforced",
                "desc": "命名/格式规范有明确的正则或模式"
            },
            {
                "check": "violation_detected",
                "desc": "不符合规范的输入被检测到"
            },
            {
                "check": "correction_suggested",
                "desc": "违规时给出修正建议"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/n018-detection-skill-rename-global-alignment.js && echo 'handler_exists:pass'",
        "expected_outcome": "不符合规范的命名/格式被检测并建议修正",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}