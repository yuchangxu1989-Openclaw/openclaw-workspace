{
  "schema": "isc.rule.v1",
  "rule_id": "N036",
  "rule_name": "memory_loss_self_recovery",
  "version": "1.0.0",
  "created_at": "2026-02-28T16:45:00+08:00",
  "author": "ISC-DTO",
  "priority": 10,
  "category": "resilience",
  "description": "记忆丢失后自主恢复，从文件系统重建规则清单，不依赖MEMORY.md",
  "trigger": {
    "type": "file_check",
    "check": "MEMORY.md_missing_or_corrupted",
    "also_on": "session_restart_without_context"
  },
  "condition": {
    "bootstrap_enabled": true,
    "can_rebuild_from_filesystem": true
  },
  "action": {
    "type": "self_heal",
    "steps": [
      "discover_isc_rules_dir",
      "ls_all_json_files",
      "parse_each_rule_file",
      "build_rule_index",
      "verify_rule_count",
      "restore_dto_subscriptions",
      "resume_pipeline"
    ],
    "discovery_paths": [
      "/root/.openclaw/workspace/skills/isc-core/rules/"
    ],
    "bootstrap_sequence": [
      "1. Discover rules directory",
      "2. Count actual rule files",
      "3. Parse rule schemas",
      "4. Rebuild rule index",
      "5. Verify DTO subscriptions",
      "6. Resume autonomous decision pipeline"
    ]
  },
  "fallback": {
    "if_filesystem_corrupted": "emergency_readonly_mode",
    "if_no_rules_found": "alert_user_and_stop"
  },
  "metadata": {
    "rationale": "确保即使MEMORY.md丢失，系统也能从文件系统自动恢复",
    "design_principle": "Source of truth is filesystem, not memory"
  }
}
