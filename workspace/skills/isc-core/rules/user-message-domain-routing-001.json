{
  "type": "routing",
  "id": "UMR002",
  "name": "user_message_domain_routing",
  "description": "基于消息payload的domain字段路由user.message，作为意图路由的降级兜底",
  "domain": "message_routing",
  "scope": "system-wide",
  "enforcement_tier": "P1_process",
  "trigger": {
    "events": ["user.general.message"],
    "condition": "intent_classification_unavailable OR intent_confidence_low",
    "actions": [
      {
        "type": "route",
        "description": "基于domain字段兜底路由到对应模块"
      }
    ]
  },
  "routing_rules": {
    "strategy": "domain_fallback",
    "prerequisite": "intent_routing_degraded",
    "routes": [
      {
        "domain": "knowledge",
        "handler": "cras-knowledge-handler",
        "description": "知识领域消息路由到CRAS模块"
      },
      {
        "domain": "development",
        "handler": "dev-task-handler",
        "description": "开发领域消息路由到dev-task模块"
      },
      {
        "domain": "content",
        "handler": "content-creation-handler",
        "description": "内容领域消息路由到content-creation模块"
      },
      {
        "domain": "analysis",
        "handler": "analysis-handler",
        "description": "分析领域消息路由到analysis模块"
      }
    ],
    "fallback": {
      "handler": "default-message-handler",
      "description": "domain未指定时的兜底处理"
    }
  },
  "metadata": {
    "version": "1.0.0",
    "created": "2026-03-05",
    "author": "system",
    "priority": 90
  }
}
