{
  "id": "rule.zhipu-capability-router-001",
  "name": "zhipu_capability_auto_router",
  "domain": "capability",
  "type": "auto_router",
  "description": "智谱能力自动路由 - 根据输入模态自动选择模型",
  "routes": [
