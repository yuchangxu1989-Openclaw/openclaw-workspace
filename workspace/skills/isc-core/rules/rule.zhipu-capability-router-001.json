    {
      "trigger": [
        "生成视频",
        "制作视频",
        "视频生成"
      ],
      "input_modal": [
        "image",
        "text"
      ],
      "model": "glm-video",
      "skill": "glm-video",
      "priority": 10
    },
    {
      "trigger": [
        "语音合成",
        "TTS",
        "文字转语音",
        "朗读"
      ],
      "input_modal": [
        "text"
      ],
      "model": "glm-tts",
      "skill": "glm-tts",
      "priority": 10
    },
    {
      "trigger": [
        "克隆声音",
        "声音克隆",
        "模仿音色"
