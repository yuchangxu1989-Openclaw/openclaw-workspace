      "input_modal": [
        "audio"
      ],
      "model": "glm-tts-clone",
      "skill": "glm-tts-clone",
      "priority": 10
    },
    {
      "trigger": [
        "语音识别",
        "ASR",
        "语音转文字",
        "转录"
