      "constraints": {
        "image_max_mb": 10,
        "pdf_max_mb": 50,
        "max_pages": 100
      },
      "model": "glm-ocr",
      "skill": "glm-ocr",
      "priority": 10
    },
    {
      "trigger": [
        "生成图片",
