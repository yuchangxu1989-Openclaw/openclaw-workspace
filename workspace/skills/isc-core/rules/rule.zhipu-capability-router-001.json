      "input_modal": [
        "audio"
      ],
      "model": "glm-asr",
      "skill": "glm-asr",
      "priority": 10
    },
    {
      "trigger": [
        "实时视频通话",
        "视频通话",
        "视频对话"
      ],
      "input_modal": [
        "video",
        "audio",
        "text"
      ],
      "output_modal": [
        "audio"
      ],
      "model": "charglm-video",
      "skill": "charglm-video",
      "priority": 10
    },
    {
      "trigger": [
        "实时语音通话",
        "语音通话",
        "语音对话"
      ],
      "input_modal": [
        "audio",
        "text"
      ],
      "output_modal": [
        "audio"
      ],
      "model": "charglm-voice",
      "skill": "charglm-voice",
      "priority": 10
    },
    {
      "trigger": [
        "深度思考",
        "学术研究",
        "复杂推理",
        "详细分析"
      ],
      "model": "glm-thinking",
      "skill": "glm-thinking",
      "priority": 5
    },
    {
      "trigger": [
        "制作PPT",
        "生成PPT",
