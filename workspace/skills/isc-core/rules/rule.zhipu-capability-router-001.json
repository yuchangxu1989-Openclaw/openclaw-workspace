      "input_modal": [
        "video"
      ],
      "model": "glm-4v",
      "skill": "glm-4v",
      "priority": 10
    },
    {
      "trigger": [
        "OCR",
        "识别文字",
        "提取文本",
        "PDF.*识别"
      ],
      "input_modal": [
        "pdf",
        "image"
