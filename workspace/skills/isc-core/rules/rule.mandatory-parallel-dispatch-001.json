{
    "id": "rule.mandatory-parallel-dispatch-001",
    "event_type": "task.dispatch.requested",
    "name": "mandatory_parallel_dispatch_for_independent_tasks",
    "description": "独立任务强制并行派发 - 禁止在Agent池充足时将无依赖关系的独立任务打包成组合型任务",
    "domain": "orchestration",
    "type": "constraint",
    "trigger": {
