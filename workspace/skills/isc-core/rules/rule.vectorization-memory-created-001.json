{
  "id": "rule.vectorization-memory-created-001",
  "name": "vectorization_memory_created",
  "domain": "vectorization",
  "type": "automation",
  "description": "记忆文件创建时自动触发向量化",
  "trigger": {
    "events": [
      "knowledge.general.created"
    ],
    "condition": "file_path OR memory_id",
    "actions": [
      {
        "type": "auto_trigger",
        "description": "执行vectorization_memory_created规则检查"
      }
    ]
  },
  "action": {
    "type": "exec",
    "command": "knowledge.general.sh",
    "args": [
      "--event=created",
      "--type=memory"
    ]
  },
  "governance": {
    "auto_execute": true
  },
  "enforcement_tier": "P2_automation",
  "created_at": "2026-03-05T03:00:00+08:00",
  "version": "1.0.0"
}