{
  "id": "rule.glm-vision-priority-001",
  "name": "glm_vision_priority",
  "domain": "capability",
  "type": "routing_rule",
  "description": "图像视频需求优先调用GLM-4V-Plus规则 - 根治遗忘",
  "trigger": {
    "type": "intent",
    "patterns": [
      "图片.*理解",
      "图像.*分析",
      "视频.*描述",
      "看图",
      "识别图片",
      "图片内容"
    ],
    "events": [
      "system.analysis.requested",
      "system.task.created",
      "session.image.received"
    ],
    "actions": [
      {
        "type": "auto_trigger",
        "description": "图像分析任务优先使用GLM视觉模型，不可用时降级到备选模型"
      }
    ],
    "event": "system.analysis.requested"
  },
  "action": {
    "type": "script",
    "target": "zhipu/glm-4v-plus",
    "fallback": "follow_openclaw_config",
    "handler": "glm-vision-priority",
    "script": "scripts/isc-hooks/rule.glm-vision-priority-001.sh"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "priority": 10
  },
  "created_at": "2026-02-25T12:52:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P1_process",
  "enforcement": "programmatic"
}