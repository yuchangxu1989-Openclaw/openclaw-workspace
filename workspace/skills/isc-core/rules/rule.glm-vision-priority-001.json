{
  "id": "rule.glm-vision-priority-001",
  "name": "glm_vision_priority",
  "domain": "capability",
  "type": "routing_rule",
  "description": "图像视频需求优先调用GLM-4V-Plus规则 - 根治遗忘",
  "trigger": {
    "type": "intent",
    "patterns": [
      "图片.*理解",
      "图像.*分析",
      "视频.*描述",
      "看图",
      "识别图片",
      "图片内容"
    ],
    "events": {
      "L1": [
        "vision.task.created",
        "message.image.received"
      ],
      "L2": [
        "image.analysis.requested"
      ]
    }
  },
  "action": {
    "type": "model_switch",
    "target": "zhipu/glm-4v-plus",
    "fallback": "claude/claude-sonnet-4-6",
    "handler": "glm-vision-priority",
    "on_failure": "retry"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "priority": 10
  },
  "created_at": "2026-02-25T12:52:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P1_process",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}