{
    "id": "N034",
    "name": "rule_identity_accuracy_validation",
    "ruleName": "规则识别与计数准确性校验",
    "domain": "governance",
    "type": "rule",
    "scope": "system",
    "priority": "high",
    "description": "强制从文件系统实际计数规则，禁止推断或缓存，确保DTO规则识别准确",
    "rationale": "防止DTO将规则类别数误认为规则总数，确保统计数据的准确性",
    "version": "1.0.0",
    "created_at": "2026-02-28T16:45:00+08:00",
    "updated_at": "2026-02-28T16:45:00+08:00",
    "trigger": {
        "conditions": [
            {
                "type": "dto_execution",
                "when": "before_rule_statistics"
            },
            {
                "type": "scheduled",
                "cron": "*/30 * * * *",
                "description": "每30分钟检查一次"
            },
            {
                "type": "manual",
                "command": "isc validate-rule-count"
            }
        ],
        "logic": "OR",
        "events": [
            "dto.rule.statistics_requested",
            "isc.rule.created",
            "isc.rule.deleted",
            "dto.general.rule_count_validation"
        ],
        "actions": [
            {
                "type": "gate_check",
                "description": "从文件系统实际扫描规则文件计数，与注册表交叉验证，禁止推断或缓存",
                "behavior": "filesystem_scan_and_crosscheck"
            },
            {
                "type": "auto_sync",
                "description": "发现计数不匹配时，自动同步注册表（差异≤5条时）",
                "behavior": "auto_sync_on_mismatch"
            }
        ]
    },
    "validation_rules": {
        "filesystem_scan": {
            "description": "必须从文件系统实际扫描规则文件",
            "scan_path": "/root/.openclaw/workspace/skills/isc-core/rules",
            "recursive": true,
            "file_pattern": "*.json",
            "exclude": [
                "*.backup.json",
                "*.tmp.json"
            ]
        },
        "id_extraction": {
            "description": "从规则文件内容提取ID",
            "required_fields": [
                "id",
                "name",
                "domain"
            ],
            "id_sources": [
                "id",
                "ruleId",
                "name"
            ],
            "fallback": "filename_stem"
        },
        "categorization": {
            "description": "按domain/category分类统计",
            "category_sources": [
                "domain",
                "category",
                "type"
            ],
            "default_category": "uncategorized"
        },
        "cross_validation": {
            "description": "交叉验证多个数据源",
            "sources": [
                "filesystem_scan",
                "rule_registry",
                "dto_subscriptions"
            ],
            "alert_on_mismatch": true
        }
    },
    "execution": {
        "mode": "validate_and_report",
        "auto_execute": true,
        "cache_allowed": false,
        "require_fresh_scan": true
    },
    "actions": {
        "on_validation": [
            {
                "order": 1,
                "action": "scan_filesystem",
                "description": "扫描文件系统获取实际规则文件列表"
            },
            {
                "order": 2,
                "action": "parse_each_rule",
                "description": "解析每个规则文件提取ID和元数据"
            },
            {
                "order": 3,
                "action": "categorize_rules",
                "description": "按类别分组统计"
            },
            {
                "order": 4,
                "action": "compare_with_registry",
                "description": "与注册表数据对比"
            },
            {
                "order": 5,
                "action": "generate_report",
                "description": "生成准确性报告"
            }
        ],
        "on_mismatch_detected": [
            {
                "order": 1,
                "action": "alert",
                "channels": [
                    "feishu",
                    "log"
                ],
                "urgency": "high",
                "message_template": "⚠️ 规则统计不匹配\n文件系统: {fs_count} 条\n注册表: {registry_count} 条\n差异: {diff_count} 条\n\n建议执行: isc sync-rule-registry"
            },
            {
                "order": 2,
                "action": "auto_sync",
                "description": "自动同步注册表（如果差异在允许范围内）",
                "max_auto_sync_diff": 5
            }
        ]
    },
    "reporting": {
        "output_format": "json",
        "report_path": "/root/.openclaw/workspace/reports/rule-accuracy-report.json",
        "include_details": true,
        "fields": [
            "total_rules",
            "total_categories",
            "rules_by_category",
            "orphaned_rules",
            "unregistered_rules",
            "timestamp"
        ]
    },
    "accuracy_requirements": {
        "rule_count_tolerance": 0,
        "category_count_tolerance": 0,
        "id_mismatch_tolerance": 0,
        "description": "规则统计必须100%准确，不允许误差"
    },
    "enforcement_tier": "P0_gate"
}