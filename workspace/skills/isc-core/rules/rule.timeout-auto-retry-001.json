{
    "id": "TIMEOUT-AUTO-RETRY-001",
    "rule_id": "ISC-TIMEOUT-AUTO-RETRY-001",
    "event_type": "subagent_completion",
    "name": "子Agent超时/失败自动重试",
    "description": "子Agent超时(timed_out/timeout)或失败(failed)时，自动入重试队列，最多重试2次。user_cancelled除外。",
    "priority": "high",
    "version": "1.0.0",
    "created": "2026-03-08",
    "category": "reliability",
    "trigger": {
        "event": "subagent_completion",
        "conditions": [
            "status in [timed_out, timeout, failed]",
            "cancel_reason != user_cancelled",
            "retry_count < 2"
        ],
        "events": [
            "isc.rule.timeout.auto.retry.001",
            "subagent_completion"
        ]
    },
    "action": {
        "type": "enqueue_retry",
        "queue_file": "logs/auto-retry-queue.json",
        "max_retry": 2,
        "processor": "scripts/process-retry-queue.sh"
    },
    "enforcement": {
        "level": "automatic",
        "implemented_in": "scripts/completion-handler.sh (Step 7)",
        "check_frequency": "on_completion + heartbeat"
    },
    "notes": [
        "重试队列由heartbeat或cron定期通过process-retry-queue.sh检查",
        "主Agent根据队列输出重新派发任务",
        "retry_count记录在看板和队列中，防止无限重试"
    ],
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/timeout-auto-retry.js",
    "scoring_rubric": {
        "completeness": 1.0,
        "handler_real": 1.0,
        "event_bound": 0.5,
        "test_covered": 0.0
    },
    "north_star_indicator": "自主闭环率",
    "gate_relevance": 0.8,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "automation-hook",
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 TIMEOUT-AUTO-RETRY-001 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/timeout-auto-retry.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/timeout-auto-retry.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}