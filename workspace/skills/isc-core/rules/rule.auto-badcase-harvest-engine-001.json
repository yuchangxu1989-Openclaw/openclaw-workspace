{
    "id": "AUTO-BADCASE-HARVEST-ENGINE-001",
    "rule_id": "ISC-EVAL-C2-AUTO-HARVEST-ENGINE-001",
    "event_type": "isc.rule.auto.badcase.harvest.engine.001",
    "description": "纠偏类、反复未果类、头痛医头类等场景自动采集为badcase，不依赖主Agent手动记忆",
    "title": "自动Badcase采集引擎",
    "events": [
        "user.feedback.correction",
        "task.failed",
        "rule.violated"
    ],
    "sensing": {
        "completion_handler": {
            "keywords": [
                "badcase",
                "违反",
                "纠偏",
                "反复未果",
                "头痛医头",
                "又忘了",
                "第N次",
                "不推看板",
                "手动触发"
            ],
            "script": "scripts/completion-handler.sh"
        },
        "main_agent_call": {
            "description": "主Agent识别到badcase场景时直接调用auto-badcase-harvest.sh"
        }
    },
    "action": {
        "script": "scripts/auto-badcase-harvest.sh",
        "params": [
            "badcase_id",
            "category",
            "description",
            "wrong_chain",
            "correct_chain",
            "root_cause"
        ],
        "handler": "badcase-harvest-engine"
    },
    "verification": {
        "check": "检查00-real-badcases.json是否新增对应badcase_id",
        "file": "tests/benchmarks/intent/c2-golden/00-real-badcases.json"
    },
    "created_at": "2026-03-08T20:29:00Z",
    "fullchain_status": "complete",
    "handler": "skills/isc-core/handlers/auto-badcase-harvest-engine.js",
    "trigger": {
        "events": [
            "isc.rule.auto.badcase.harvest.engine.001"
        ]
    },
    "plan": {
        "description": "自动采集badcase的执行计划",
        "steps": [
            {
                "step": 1,
                "action": "detect_pattern",
                "desc": "检测会话中纠偏/反复未果/头痛医头模式"
            },
            {
                "step": 2,
                "action": "extract_context",
                "desc": "提取错误链(wrong_chain)和正确链(correct_chain)"
            },
            {
                "step": 3,
                "action": "classify_badcase",
                "desc": "分类badcase类型(纠偏/循环/表面修复)"
            },
            {
                "step": 4,
                "action": "persist_badcase",
                "desc": "写入badcase存储，生成唯一badcase_id"
            },
            {
                "step": 5,
                "action": "emit_event",
                "desc": "发送badcase.created事件供下游消费"
            }
        ],
        "rollback": {
            "strategy": "delete_on_failure",
            "desc": "采集失败时删除已写入的不完整badcase记录"
        }
    }
}
