            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/pipeline-benchmark-design-document-layered.js && echo 'handler_exists:pass'",
        "expected_outcome": "低质量产出被拦截，高质量产出通过",
