{
  "id": "rule.cron-task-model-requirement-001",
  "name": "cron_task_model_requirement",
  "domain": "cron",
  "type": "validation_rule",
  "description": "定时任务必须指定模型规则 - GLM-5优先，Claude-Sonnet备选",
  "trigger": {
    "type": "event",
    "patterns": [
      "cron:create",
      "cron:update",
      "cron:validate"
    ]
  },
  "condition": {
    "payload": {
      "kind": "agentTurn"
    }
  },
  "validation": {
    "required_field": "model",
    "model_priority": [
      "zhipu/glm-5"
    ],
    "error_message": "定时任务必须指定模型。优先级：1) GLM-5 (强推理) 2) Claude Sonnet (备选)"
  },
  "action": {
    "type": "enforce",
    "on_missing": "reject",
    "default_model": "claude/claude-sonnet-4-6",
    "auto_fix": false
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "priority": 20
  },
  "created_at": "2026-02-26T15:40:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P0_gate"
}