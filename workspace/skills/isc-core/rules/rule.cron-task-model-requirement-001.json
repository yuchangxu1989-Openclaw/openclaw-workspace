{
    "id": "rule.cron-task-model-requirement-001",
    "event_type": "lto.task.created",
    "name": "cron_task_model_requirement",
    "description": "定时任务模型规范 - 必须指定模型，跟随openclaw.json配置",
    "domain": "cron",
    "type": "validation_rule",
    "trigger": {
        "type": "event",
        "patterns": [
            "lto.general.create",
            "lto.general.update",
            "lto.general.requested"
        ],
        "events": [
            "lto.task.created",
            "lto.task.updated",
            "lto.task.validated"
        ],
        "actions": [
            {
                "type": "gate-check",
                "description": "定时任务创建/更新时验证必须指定model字段，未指定则拒绝创建",
                "behavior": "reject_cron_without_model"
            },
            {
                "type": "auto_fix",
                "description": "缺少model字段时，跟随openclaw.json主配置模型",
                "behavior": "apply_default_model"
            }
        ],
        "event": "lto.task.created"
    },
    "condition": {
        "payload": {
            "kind": "agentTurn"
        }
    },
    "validation": {
        "required_field": "model",
        "model_priority": [
            "zhipu/glm-5"
        ],
        "error_message": "定时任务必须指定模型。优先级：1) GLM-5 (强推理) 2) Claude Sonnet (备选)"
    },
    "action": {
        "type": "enforce",
        "on_missing": "reject",
        "default_model": "follow_openclaw_config",
        "auto_fix": false,
        "handler": "cron-task-model-requirement",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.cron-task-model-requirement-001.sh"
    },
    "governance": {
        "auto_execute": true,
        "councilRequired": false,
        "priority": 20
    },
    "created_at": "2026-02-26T15:40:00+08:00",
    "version": "1.0.0",
    "enforcement_tier": "P0_gate",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/cron-task-model-requirement.js",
    "fullchain_status": "expanded",
    "verification": {
        "method": "automation_trigger_check",
        "description": "验证自动化规则 rule.cron-task-model-requirement-001 的触发和执行链路",
        "assertions": [
            {
                "check": "trigger_event_subscribed",
                "desc": "事件订阅已注册: lto.task.created, lto.task.updated, lto.task.validated"
            },
            {
                "check": "handler_executable",
                "desc": "Handler可执行: skills/isc-core/handlers/cron-task-model-requirement.js"
            },
            {
                "check": "output_generated",
                "desc": "触发后产出符合预期的输出"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/cron-task-model-requirement.js && echo 'handler_exists:pass'",
        "expected_outcome": "事件触发后自动执行，产出正确输出",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}