{
  "id": "rule.cron-task-model-requirement-001",
  "name": "cron_task_model_requirement",
  "domain": "cron",
  "type": "validation_rule",
  "description": "定时任务模型规范 - 必须指定模型，跟随openclaw.json配置",
  "trigger": {
    "type": "event",
    "patterns": [
      "dto.general.create",
      "dto.general.update",
      "dto.general.requested"
    ],
    "events": [
      "dto.task.created",
      "dto.task.updated",
      "dto.task.validated"
    ],
    "actions": [
      {
        "type": "gate-check",
        "description": "定时任务创建/更新时验证必须指定model字段，未指定则拒绝创建",
        "behavior": "reject_cron_without_model"
      },
      {
        "type": "auto_fix",
        "description": "缺少model字段时，跟随openclaw.json主配置模型",
        "behavior": "apply_default_model"
      }
    ],
    "event": "dto.task.created"
  },
  "condition": {
    "payload": {
      "kind": "agentTurn"
    }
  },
  "validation": {
    "required_field": "model",
    "model_priority": [
      "zhipu/glm-5"
    ],
    "error_message": "定时任务必须指定模型。优先级：1) GLM-5 (强推理) 2) Claude Sonnet (备选)"
  },
  "action": {
    "type": "enforce",
    "on_missing": "reject",
    "default_model": "follow_openclaw_config",
    "auto_fix": false,
    "handler": "cron-task-model-requirement"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "priority": 20
  },
  "created_at": "2026-02-26T15:40:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P0_gate"
}
