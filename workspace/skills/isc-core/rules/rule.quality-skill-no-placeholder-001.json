{
  "id": "ISC-SKILL-QUALITY-001",
  "name": "skill_no_placeholder",
  "domain": "quality",
  "type": "rule",
  "scope": "skill",
  "description": "禁止占位符技能 - 技能必须有实质性实现",
  "rationale": "占位符技能占用命名空间，误导用户，浪费审计资源",
  "check_criteria": {
    "must_have": [
      "SKILL.md 文件存在且内容>100字",
      "至少一个可执行代码文件(.js/.py/.sh)",
      "代码文件必须包含实际逻辑，不是空函数"
    ],
    "must_not_have": [
      "空目录结构",
      "只有框架没有实现",
      "SKILL.md 只有标题没有内容"
    ]
  },
  "severity": "high",
  "auto_fix": false,
  "created_at": "2026-02-25T05:53:00+08:00",
  "version": "1.0.0",
  "trigger": {
