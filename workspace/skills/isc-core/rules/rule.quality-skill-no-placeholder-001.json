        "message": "Rule ISC-SKILL-QUALITY-001 violation"
      }
    ],
    "event": "isc.rule.matched"
  },
  "enforcement_tier": "P0_gate",
  "action": {
    "type": "check",
    "handler": "eval-quality-check",
