{
    "id": "deep-think-auto-delegate-001",
    "event_type": "isc.rule.deep.think.auto.delegate.001",
    "name": "深度思考意图自动委派子Agent",
    "description": "当用户消息命中深度思考意图关键词且预估处理时间>30秒时，主Agent必须spawn子Agent处理，自身只做结果整合和通信",
    "priority": "high",
    "version": "1.0.0",
    "category": "delegation",
    "enforcement": "programmatic",
    "trigger": {
        "type": "user_message",
        "conditions": [
            {
                "type": "keyword_match",
                "source": "config/deep-think-keywords.json",
                "field": "keywords"
            },
            {
                "type": "estimated_processing_time",
                "threshold_seconds": 30
            }
        ],
        "logic": "AND",
        "events": [
            "isc.rule.deep.think.auto.delegate.001"
        ]
    },
    "action": {
        "type": "spawn_subagent",
        "detection_script": "scripts/detect-deep-think-intent.sh",
        "agent_selection": "from_script_output",
        "main_agent_role": "result_integration_and_communication_only"
    },
    "violation": {
        "classification": "badcase",
        "message": "主Agent直接深度思考而未委派子Agent，违反deep-think-auto-delegate-001"
    },
    "created": "2026-03-08",
    "status": "active",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/deep-think-auto-delegate.js",
    "verification": {
        "method": "intent_routing_check",
        "description": "验证意图路由规则 deep-think-auto-delegate-001 的分发正确性",
        "assertions": [
            {
                "check": "intent_recognized",
                "desc": "目标意图被正确识别"
            },
            {
                "check": "route_correct",
                "desc": "意图被路由到正确的处理器"
            },
            {
                "check": "fallback_handled",
                "desc": "无法识别的意图有fallback处理"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/deep-think-auto-delegate.js && echo 'handler_exists:pass'",
        "expected_outcome": "意图准确识别并路由到正确处理器",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}