{
  "id": "rule.aeo-evaluation-set-registry-001",
  "name": "aeo_evaluation_set_registry_standard",
  "domain": "aeo",
  "type": "standard",
  "description": "AEO评测集注册管理标准 - 统一评测集的收录、分类和检索",
  "standard": {
    "version": "1.0.0",
    "registryLocation": {
      "path": "skills/aeo/unified-evaluation-sets/registry.json",
      "schema": "isc://evaluation-set-registry.schema.json"
    },
    "idFormat": {
      "pattern": "eval.{skill-name}.{sequence}",
      "example": "eval.weather-skill.001",
      "constraints": [
        "skill-name使用kebab-case",
        "sequence使用3位数字，从001开始"
      ]
    },
    "storageModes": {
      "inline": {
        "description": "评测用例内联存储在registry.json中",
        "maxCases": 10,
        "useCase": "黄金标准核心用例"
      },
      "file": {
        "description": "评测用例存储在独立文件",
        "naming": "{set-id}.json",
        "location": "与registry.json同目录",
        "useCase": "标准评测集"
      },
      "url": {
        "description": "远程托管评测集",
        "useCase": "外部协作评测集"
      }
    },
    "standardLevels": {
      "golden": {
        "description": "黄金标准评测集",
        "criteria": [
          "经过人工审核",
          "覆盖核心功能路径",
          "作为技能准入门槛",
          "版本锁定，变更需审批"
        ],
        "badge": "🥇",
        "displayColor": "#FFD700"
      },
      "standard": {
        "description": "标准评测集",
        "criteria": [
          "自动化生成或维护",
          "常规回归测试",
          "可随技能迭代更新"
        ],
        "badge": "🥈",
        "displayColor": "#C0C0C0"
      },
      "experimental": {
        "description": "实验性评测集",
        "criteria": [
          "探索性测试",
          "新功能预览",
          "不稳定，可能删除"
        ],
        "badge": "🧪",
        "displayColor": "#9B59B6"
      }
    },
    "classification": {
      "bySkill": {
        "description": "按技能分类",
        "mandatory": true,
        "indexField": "targetSkill"
      },
      "byTrack": {
        "description": "按评测轨道分类",
        "values": [
          "ai-effect",
          "functional-quality",
          "hybrid"
        ],
        "mandatory": true
      },
      "byStandard": {
        "description": "按标准级别分类",
        "mandatory": true
      }
    },
    "requiredMetadata": [
      "description",
      "author",
      "createdAt",
      "version",
      "testCaseCount"
    ],
    "dtoAlignment": {
      "description": "必须与DTO订阅对齐",
      "rules": [
        "每个golden标准评测集对应一个DTO订阅",
        "subscriptionId格式: N{3位数字}",
        "autoTrigger=true表示技能更新时自动触发评测"
      ]
    }
  },
  "governance": {
    "registryMaintainer": "aeo",
    "reviewRequired": {
      "golden": true,
      "standard": false,
      "experimental": false
    },
    "autoValidate": true
  },
  "created_at": "2026-02-26T19:50:00+08:00",
  "version": "1.0.0",
  "trigger": {
    "events": [
      "isc:rule:matched",
      "isc:category:aeo"
    ],
    "actions": [
      {
        "type": "log",
        "level": "info"
      }
    ]
  }
}