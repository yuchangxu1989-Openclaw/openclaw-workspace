{
  "id": "rule.public-skill-quality-gate-001",
  "version": "1.0.0",
  "name": "可销售技能质量门禁",
  "description": "skills/public/下的技能必须满足销售质量标准才能发布",
  "priority": "P0_gate",
  "domain": "skill",
  "category": "quality",
  "trigger": {
    "events": [
      "skill.public.pre_publish",
      "skill.public.modified",
      "git.commit.skills_public"
    ]
  },
  "conditions": {
    "quality_checklist": [
      "SKILL.md有完整frontmatter（name+description）",
      "description包含触发词和NOT for排除项",
      "零外部npm依赖或明确声明依赖",
      "无敏感信息（API key/密码/内部路径）",
      "有使用示例（CLI或代码调用）",
      "有前置条件说明",
      "文件结构符合skill-creator标准"
    ]
  },
  "action": {
    "perception": "git pre-commit hook检测skills/public/变更",
    "cognition": "逐项检查quality_checklist",
    "execution": [
      "全部通过 → 允许提交",
      "未通过 → 阻断提交，列出不达标项"
    ],
    "handler": "public-skill-quality-gate",
    "type": "handler"
  },
  "created_at": "2026-03-06T02:38:00Z",
  "created_by": "ruleify"
}