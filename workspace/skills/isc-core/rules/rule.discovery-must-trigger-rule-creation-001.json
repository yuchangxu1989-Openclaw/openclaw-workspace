{
    "id": "rule.discovery-must-trigger-rule-creation-001",
    "event_type": "system.issue.discovered",
    "name": "发现问题必须同步创建规则",
    "description": "当发现系统设计缺陷、评测方法论问题、架构盲区时，修复问题的同时必须创建对应的ISC规则+事件绑定+DTO执行链，防止同类问题再次发生。修复不带规则=只治标不治本。",
    "priority": "P0",
    "version": "1.0.0",
    "category": "meta-governance",
    "trigger": {
        "events": [
            "system.issue.discovered",
            "architecture.gap.detected",
            "aeo.methodology.upgraded"
        ],
        "actions": [
            "isc.rule.auto_create",
            "event.binding.ensure",
            "lto.task.ensure"
        ],
        "event": "system.issue.discovered"
    },
    "conditions": {
        "must": "每次修复必须产出三件套：规则+事件+执行链，缺任何一个视为未完成"
    },
    "rationale": "用户原话：'当你发现不能用单轮来做评测集的时候，有做跟规则、事件相关的自动化识别与加载么？'——答案是没有，这是系统性遗漏。",
    "created_at": "2026-03-06T00:58:00+08:00",
    "action": {
        "handler": "discovery-rule-creation",
        "type": "script",
        "script": "scripts/isc-hooks/rule.discovery-must-trigger-rule-creation-001.sh"
    },
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler_path": "infrastructure/event-bus/handlers/discovery-must-trigger-rule-creation-001.sh",
    "handler": "skills/isc-core/handlers/discovery-must-trigger-rule-creation.js",
    "verification": {
        "method": "quality_gate_check",
        "description": "验证质量规则 rule.discovery-must-trigger-rule-creation-001 的检查能力",
        "assertions": [
            {
                "check": "quality_criteria_defined",
                "desc": "质量标准有明确的判定条件"
            },
            {
                "check": "pass_fail_distinguishable",
                "desc": "合格与不合格的产出可被准确区分"
            },
            {
                "check": "feedback_actionable",
                "desc": "不合格时反馈的问题可被执行者修复"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/discovery-must-trigger-rule-creation.js && echo 'handler_exists:pass'",
        "expected_outcome": "低质量产出被拦截，高质量产出通过",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}