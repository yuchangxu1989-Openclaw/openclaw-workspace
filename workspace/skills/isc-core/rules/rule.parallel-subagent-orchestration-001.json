{
    "id": "rule.parallel-subagent-orchestration-001",
    "rule_id": "PARALLEL_SUBAGENT_OR",
    "event_type": "orchestration.general.requested",
    "name": "parallel_subagent_orchestration",
    "description": "并行子Agent编排规则 - DTO调度多Agent并行执行复杂工作流",
    "domain": "orchestration",
    "type": "workflow",
    "trigger": {
        "type": "manual_or_event",
        "events": [
            "orchestration.general.requested",
            "orchestration.general.detected"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "复杂任务自动拆分为并行子Agent执行，协调结果汇总并处理冲突"
            }
        ],
        "event": "orchestration.general.requested"
    },
    "workflow": {
        "stages": [
            {
                "name": "analysis",
                "type": "parallel",
                "agents": [
                    {
                        "role": "analyzer",
                        "task": "需求分析",
                        "timeout": 120
                    },
                    {
                        "role": "researcher",
                        "task": "背景调研",
                        "timeout": 180
                    }
                ]
            },
            {
                "name": "synthesis",
                "type": "sequential",
                "depends_on": [
                    "analysis"
                ],
                "agents": [
                    {
                        "role": "synthesizer",
                        "task": "综合分析",
                        "timeout": 120
                    }
                ]
            },
            {
                "name": "execution",
                "type": "parallel",
                "depends_on": [
                    "synthesis"
                ],
                "agents": [
                    {
                        "role": "coder",
                        "task": "代码实现",
                        "timeout": 300
                    },
                    {
                        "role": "writer",
                        "task": "文档编写",
                        "timeout": 180
                    }
                ]
            }
        ]
    },
    "executor": {
        "module": "parallel-subagent",
        "action": "executeWorkflow",
        "config": {
            "max_parallel": 5,
            "retry_failed": true,
            "aggregate_results": true
        }
    },
    "governance": {
        "auto_execute": true,
        "councilRequired": false,
        "approval_threshold": "simple_majority"
    },
    "created_at": "2026-02-25T11:33:00+08:00",
    "version": "1.0.0",
    "enforcement_tier": "P1_process",
    "action": {
        "handler": "parallel-subagent-orchestration",
        "type": "script",
        "script": "scripts/isc-hooks/rule.parallel-subagent-orchestration-001.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/parallel-subagent-orchestration.js",
    "scoring_rubric": "handler可执行+逻辑匹配描述=60%; 事件订阅完整=20%; 测试覆盖=20%",
    "north_star_indicator": {
        "primary": "言出法随达成率",
        "secondary": "自主闭环率"
    },
    "gate_relevance": 0.85,
    "process_indicators": [
        "handler_exists:True",
        "event_subscribed:True",
        "test_exists:False"
    ],
    "layer": "L3-programmatic",
    "verification": {
        "method": "orchestration_flow_check",
        "description": "验证编排规则 rule.parallel-subagent-orchestration-001 的调度正确性",
        "assertions": [
            {
                "check": "dispatch_target_valid",
                "desc": "调度目标Agent/处理器有效"
            },
            {
                "check": "task_routed_correctly",
                "desc": "任务被路由到正确的执行者"
            },
            {
                "check": "result_collected",
                "desc": "执行结果被正确收集和报告"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/parallel-subagent-orchestration.js && echo 'handler_exists:pass'",
        "expected_outcome": "任务正确调度到目标执行者并收集结果",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}