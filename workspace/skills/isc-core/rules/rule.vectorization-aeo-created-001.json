{
  "id": "rule.vectorization-aeo-created-001",
  "name": "vectorization_aeo_created",
  "domain": "vectorization",
  "type": "automation",
  "description": "AEO评测用例创建时自动触发向量化",
  "trigger": {
    "events": [
      "aeo.evaluation_set.created"
    ],
    "condition": "evaluation_set_id OR file_path",
    "actions": [
      {
        "type": "auto_trigger",
        "description": "执行vectorization_aeo_created规则检查"
      }
    ]
  },
  "action": {
    "type": "exec",
    "command": "knowledge.general.sh",
    "args": [
      "--event=created",
      "--type=aeo"
    ],
    "handler": "handlers/eval-quality-check.js"
  },
  "governance": {
    "auto_execute": true
  },
  "enforcement_tier": "P2_automation",
  "created_at": "2026-03-05T03:00:00+08:00",
  "version": "1.0.0"
}