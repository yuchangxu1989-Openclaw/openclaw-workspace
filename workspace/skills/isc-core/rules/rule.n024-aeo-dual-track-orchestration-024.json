{
    "id": "rule.n024-aeo-dual-track-orchestration-024",
    "event_type": "aeo_evaluation_required",
    "name": "aeo_dual_track_orchestration",
    "description": "AEO双轨运营编排 - 自动区分AI效果运营和功能质量运营，分别执行评测",
    "type": "orchestration",
    "domain": "quality_assurance",
    "scope": "system-wide",
    "trigger": {
        "events": [
            "aeo_evaluation_required",
            "skill_test_triggered"
        ],
        "condition": "evaluation_request_received",
        "actions": [
            {
                "type": "aeo-evaluation-required",
                "handler": "aeo-evaluation-required",
                "description": "收到评测请求时，自动区分AI效果运营和功能质量运营双轨道，分别执行评测并合并报告"
            }
        ]
    },
    "dual_track": {
        "ai_effect_track": {
            "name": "AI效果运营",
            "focus": "模型智能程度",
            "dimensions": [
                "accuracy",
                "creativity",
                "relevance",
                "reasoning"
            ],
            "evaluation_method": "model_output_assessment",
            "applicable_when": [
                "skill_has_ai_component",
                "output_is_generated_content",
                "requires_semantic_evaluation"
            ]
        },
        "function_quality_track": {
            "name": "功能质量运营",
            "focus": "系统功能完整性",
            "dimensions": [
                "availability",
                "reliability",
                "performance",
                "correctness"
            ],
            "evaluation_method": "functional_testing",
            "applicable_when": [
                "all_skills",
                "api_interface_testing",
                "system_behavior_validation"
            ]
        }
    },
    "orchestration_logic": {
        "step_1": "分析技能类型，判断适用的轨道；若为意图识别评测，则强制进入LLM主判断链，并记录关键词/正则辅助交叉匹配信号",
        "step_2": "AI效果轨道：执行语义评测、生成质量评估",
        "step_3": "功能质量轨道：执行接口测试、性能测试",
        "step_4": "合并双轨结果，生成综合报告"
    },
    "output": {
        "ai_effect_report": "aeo/reports/{skill}-ai-effect.json",
        "function_quality_report": "aeo/reports/{skill}-function-quality.json",
        "combined_dashboard": "aeo/dashboard/{skill}-combined.html"
    },
    "governance": {
        "auto_execute": true,
        "priority": "HIGH"
    },
    "enforcement_tier": "P1_process",
    "action": {
        "type": "script",
        "handler": "eval-quality-check",
        "script": "scripts/isc-hooks/rule.n024-aeo-dual-track-orchestration-024.sh"
    },
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/n024-aeo-dual-track-orchestration.js",
    "verification": {
        "method": "quality_gate_check",
        "description": "验证质量规则 rule.n024-aeo-dual-track-orchestration-024 的检查能力",
        "assertions": [
            {
                "check": "quality_criteria_defined",
                "desc": "质量标准有明确的判定条件"
            },
            {
                "check": "pass_fail_distinguishable",
                "desc": "合格与不合格的产出可被准确区分"
            },
            {
                "check": "feedback_actionable",
                "desc": "不合格时反馈的问题可被执行者修复"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/n024-aeo-dual-track-orchestration.js && echo 'handler_exists:pass'",
        "expected_outcome": "低质量产出被拦截，高质量产出通过",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}