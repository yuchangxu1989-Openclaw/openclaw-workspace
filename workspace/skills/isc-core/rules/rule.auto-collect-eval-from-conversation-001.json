{
  "id": "rule.auto-collect-eval-from-conversation-001",
  "rule_name": "自动采集评测样本",
  "version": "1.0.0",
  "severity": "high",
  "description": "每次会话中用户的复杂发言（IC3-IC5、>=40字、含教学/纠偏/多意图）自动收录为评测样本。必须用原话原样不缩写不改写，必须带完整上下文。",
  "category": "aeo",
  "trigger": {
    "events": [
      "session.message.received"
    ],
    "actions": [
      "aeo.eval.triggered"
    ],
    "event": "session.message.received"
  },
  "conditions": {
    "complexity": [
      "IC3",
      "IC4",
      "IC5"
    ],
    "min_length": 40,
    "content_types": [
      "teaching",
      "correction",
      "multi_intent"
    ],
    "preservation": "verbatim_with_full_context"
  },
  "rationale": {
    "source": "用户教学"
  },
  "enforcement_tier": "P1_check",
  "created_at": "2026-03-06T00:28:00+08:00",
  "action": {
    "type": "check",
    "handler": "eval-quality-check",
    "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.auto-collect-eval-from-conversation-001.sh"
  },
  "enforcement": "programmatic"
}
