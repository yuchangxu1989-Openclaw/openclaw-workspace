{
  "id": "rule.auto-evomap-sync-trigger-001",
  "legacyId": "R003",
  "name": "auto_evomap_sync",
  "domain": "sync",
  "type": "rule",
  "scope": "skill",
  "description": "自动EvoMap同步触发规则 - 技能创建或更新时同步到EvoMap网络",
  "condition": "skill_created OR skill_updated",
  "trigger": {
    "events": {
      "L1": [
        "skill.published",
        "skill.version.updated",
        "skill.lifecycle.status_changed"
      ]
    },
    "condition": "skill_created OR skill_updated"
  },
  "priority": 7,
  "action": {
    "type": "auto",
    "handler": "sync_to_evomap_network",
    "on_failure": "retry"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false
  },
  "created_at": "2026-02-25T06:32:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P1_process",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}