{
  "schema": "isc.rule.v1",
  "rule_id": "N035",
  "rule_name": "rule_trigger_integrity_monitor",
  "version": "1.0.0",
  "created_at": "2026-02-28T16:45:00+08:00",
  "author": "ISC-DTO",
  "priority": 8,
  "category": "monitoring",
  "description": "规则触发完整性监控，检查未触发规则并报告原因",
  "trigger": {
    "type": "post_execution",
    "after": "dto_pipeline_complete",
    "cron": "0 */2 * * *"
  },
  "condition": {
    "check_type": "untriggered_rules",
    "threshold": {
      "alert_if_untriggered_ratio": 0.3,
      "max_untriggered_without_reason": 5
    }
  },
  "action": {
    "type": "analyze_and_report",
    "steps": [
      "count_total_rules",
      "count_triggered_rules",
      "calculate_untriggered",
      "analyze_why_not_triggered",
      "generate_report"
    ],
    "report_format": "feishu_card",
    "include": [
      "total_rules_count",
      "triggered_count",
      "untriggered_count",
      "untriggered_list",
      "reason_analysis"
    ]
  },
  "escalation": {
    "if_untriggered_gt_50_percent": "detailed_root_cause_analysis",
    "if_untriggered_gt_10": "urgent_user_notification"
  },
  "metadata": {
    "current_status": "61条规则，27条已触发，34条未触发",
    "rationale": "确保所有规则都被验证执行，或明确说明未触发原因"
  }
}
