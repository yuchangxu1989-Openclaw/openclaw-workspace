{
    "id": "rule.arch-gate-before-action-001",
    "event_type": "skill.lifecycle.created",
    "description": "任何影响系统状态的操作（提交代码、发布技能、生成报告、关闭Day）必须通过至少一个自动化Gate检查。无Gate的操作路径视为安全漏洞。",
    "rule_name": "Gate Before Action — 行动前必有门禁",
    "version": "1.0.0",
    "severity": "critical",
    "source": "Day 1/2设计债务复盘 — AP-001架构原则，根因α修复",
    "trigger": {
        "events": [
            "skill.lifecycle.created",
            "skill.lifecycle.published",
            "isc.rule.created",
            "quality.benchmark.completed",
            "orchestration.pipeline.completed",
            "system.day.closure_requested"
        ]
    },
    "action": {
        "type": "gate",
        "handler": "gate-before-action",
        "on_failure": "reject"
    },
    "enforcement": "runtime_binding",
    "enforcement_tier": "P0_gate",
    "schema_version": "2.0",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/arch-gate-before-action.js",
    "verification": {
        "method": "gate_enforcement_check",
        "description": "验证门禁规则 rule.arch-gate-before-action-001 的拦截能力",
        "assertions": [
            {
                "check": "handler_exists",
                "desc": "Handler文件存在且可执行: skills/isc-core/handlers/arch-gate-before-action.js"
            },
            {
                "check": "violation_blocked",
                "desc": "违规操作被成功拦截并记录日志"
            },
            {
                "check": "compliant_passes",
                "desc": "合规操作正常通过不被误拦"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/arch-gate-before-action.js && echo 'handler_exists:pass'",
        "expected_outcome": "违规操作100%被拦截，合规操作0%误拦",
        "timeout_seconds": 30,
        "on_failure": "block_and_alert"
    }
}