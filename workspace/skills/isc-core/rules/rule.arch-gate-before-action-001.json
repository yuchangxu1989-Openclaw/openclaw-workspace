{
  "id": "rule.arch-gate-before-action-001",
  "rule_name": "Gate Before Action — 行动前必有门禁",
  "version": "1.0.0",
  "severity": "critical",
  "description": "任何影响系统状态的操作（提交代码、发布技能、生成报告、关闭Day）必须通过至少一个自动化Gate检查。无Gate的操作路径视为安全漏洞。",
  "source": "Day 1/2设计债务复盘 — AP-001架构原则，根因α修复",
  "trigger": {
    "events": [
      "skill.lifecycle.created",
      "skill.lifecycle.published",
      "isc.rule.created",
      "quality.benchmark.completed",
      "orchestration.pipeline.completed",
      "system.day.closure_requested"
    ]
  },
  "action": {
    "type": "gate",
    "handler": "gate-before-action",
    "on_failure": "reject"
  },
  "enforcement": "runtime_binding",
  "enforcement_tier": "P0_gate",
  "schema_version": "2.0",
  "fullchain_status": "expanded",
  "handler": "scripts/isc-hooks/rule.arch-gate-before-action-001.sh"
}
