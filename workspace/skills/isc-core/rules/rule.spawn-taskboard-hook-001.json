{
    "id": "ISC-SPAWN-TASKBOARD-HOOK-001",
    "rule_id": "rule.spawn-taskboard-hook-001",
    "event_type": "agent.task.spawned",
    "name": "Spawn必须登记TaskBoard",
    "description": "主Agent每次sessions_spawn后必须调用register-task登记到task-board",
    "trigger": {
        "event": "agent.task.spawned",
        "events": [
            "isc.rule.spawn.taskboard.hook.001",
            "agent.task.spawned"
        ]
    },
    "action": {
        "type": "script",
        "script": "scripts/isc-hooks/ISC-SPAWN-TASKBOARD-HOOK-001.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/spawn-taskboard-hook.js",
    "scoring_rubric": {
        "completeness": 1,
        "handler_real": 1,
        "event_bound": 0.5,
        "test_covered": 0
    },
    "north_star_indicator": "言出法随达成率",
    "gate_relevance": 0.6,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "operational-rule",
    "verification": {
        "method": "report_delivery_check",
        "description": "验证报告规则 ISC-SPAWN-TASKBOARD-HOOK-001 的产出和投递",
        "assertions": [
            {
                "check": "report_generated",
                "desc": "报告内容被正确生成"
            },
            {
                "check": "format_correct",
                "desc": "报告格式符合预期（Markdown/Card/PDF）"
            },
            {
                "check": "delivery_confirmed",
                "desc": "报告投递到目标渠道"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/spawn-taskboard-hook.js && echo 'handler_exists:pass'",
        "expected_outcome": "报告正确生成并投递到目标渠道",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}