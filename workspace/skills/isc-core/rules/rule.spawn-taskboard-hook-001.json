{
  "id": "ISC-SPAWN-TASKBOARD-HOOK-001",
  "name": "Spawn必须登记TaskBoard",
  "description": "主Agent每次sessions_spawn后必须调用register-task登记到task-board",
  "trigger": {
    "event": "agent.task.spawned",
    "events": [
      "isc.rule.spawn.taskboard.hook.001"
    ]
  },
  "action": {
    "type": "script",
    "script": "scripts/isc-hooks/ISC-SPAWN-TASKBOARD-HOOK-001.sh"
  },
  "enforcement": "programmatic",
  "handler": "scripts/isc-hooks/ISC-SPAWN-TASKBOARD-HOOK-001.sh"
}
