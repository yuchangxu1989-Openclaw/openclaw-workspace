{
    "id": "rule.eval-mining-intent-route-001",
    "event_type": "user.intent.eval_mining",
    "name": "评测集挖掘意图路由",
    "description": "用户要求挖掘/补充/生成评测集时，自动路由到eval-mining技能",
    "trigger": {
        "events": [
            "user.intent.eval_mining"
        ]
    },
    "keywords_hint": [
        "挖掘评测",
        "补充评测集",
        "生成评测",
        "C2用例",
        "评测数据",
        "挖数据",
        "评测集补全"
    ],
    "action": "route_to_skill",
    "target_skill": "skills/public/eval-mining/",
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/eval-mining-intent-route.js",
    "verification": {
        "method": "quality_gate_check",
        "description": "验证质量规则 rule.eval-mining-intent-route-001 的检查能力",
        "assertions": [
            {
                "check": "quality_criteria_defined",
                "desc": "质量标准有明确的判定条件"
            },
            {
                "check": "pass_fail_distinguishable",
                "desc": "合格与不合格的产出可被准确区分"
            },
            {
                "check": "feedback_actionable",
                "desc": "不合格时反馈的问题可被执行者修复"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/eval-mining-intent-route.js && echo 'handler_exists:pass'",
        "expected_outcome": "低质量产出被拦截，高质量产出通过",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}