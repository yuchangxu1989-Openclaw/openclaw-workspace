{
  "rule_id": "rule.quality-over-efficiency-over-cost-001",
  "rule_name": "选型铁律：质量>效率>成本",
  "description": "任何技术选型决策必须遵循质量>效率>成本的优先级。越重要的环节越用最强方案，不允许在关键环节为省成本或求快而降级方案质量。",
  "schema_version": "2.0",
  "severity": "critical",
  "category": "architecture_decision",
  "trigger": {
    "events": {
      "L1": [
        "architecture.decision.model_selection",
        "architecture.decision.tool_selection",
        "architecture.decision.approach_selection",
        "architecture.decision.verification_method_selection",
        "architecture.decision.delivery_scope_selection",
        "architecture.decision.execution_mode_selection",
        "architecture.decision.task_granularity_selection",
        "architecture.decision.wait_strategy_selection"
      ],
      "L2": [
        "quality.review.selection_rationality_check"
      ]
    },
    "condition": "selection_decision_made AND task_importance_level EXISTS"
  },
  "action": {
    "type": "gate",
    "handler": "quality-analyst-review",
    "checks": [
      {
        "id": "importance_match",
        "description": "方案强度是否匹配任务重要性：P0任务必须用最强方案，P1可适度权衡效率，P2才考虑成本",
        "fail_action": "reject"
      },
      {
        "id": "no_critical_downgrade",
        "description": "关键环节禁止降级：ISC规则治理、语义判断、架构决策、验收测试等不允许用弱模型/简单方案",
        "fail_action": "reject"
      },
      {
        "id": "cost_only_for_batch",
        "description": "成本优化仅适用于高频批量定时任务（如GLM-5用于定时跑批），其他场景成本不作为选型因素",
        "fail_action": "warn"
      }
    ],
    "on_failure": "reject",
    "quality_analyst_report_fields": [
      "选型决策描述",
      "任务重要性级别(P0/P1/P2)",
      "可选方案对比",
      "选中方案及理由",
      "是否符合质量>效率>成本"
    ]
  },
  "examples": [
    {
      "scenario": "ISC规则去重用Jaccard关键词匹配",
      "result": "REJECT",
      "reason": "ISC规则是系统约束层（P0），语义判断必须用LLM（Opus），不能用关键词匹配降级"
    },
    {
      "scenario": "开发阶段子Agent用GLM-5",
      "result": "REJECT",
      "reason": "开发阶段要质量和效率，GLM-5仅用于定时批量任务降本"
    },
    {
      "scenario": "定时向量化批处理用GLM-5",
      "result": "APPROVE",
      "reason": "高频定时任务，质量要求相对宽容，适合成本优化"
    },
    {
      "scenario": "3个无依赖子任务串行执行",
      "result": "REJECT",
      "reason": "无依赖关系的任务必须并行，串行浪费效率，违反效率优先级"
    },
    {
      "scenario": "等ISC治理完成后才启动Day2其他任务",
      "result": "REJECT",
      "reason": "ISC治理和Day2交付验证无强依赖，应并行推进"
    },
    {
      "scenario": "意图识别验证用Sonnet",
      "result": "APPROVE",
      "reason": "同水平模型可验证功能正确性，后期补效果对比即可"
    }
  ],
  "metadata": {
    "created": "2026-03-05",
    "source": "用户亲授选型原则",
    "anti_entropy": true,
    "priority": "highest"
  }
}
