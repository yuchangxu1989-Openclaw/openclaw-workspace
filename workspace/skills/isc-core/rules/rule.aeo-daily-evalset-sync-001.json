  "handler": "scripts/aeo-daily-evalset-sync.sh",
  "handler_type": "shell",
  "tags": ["aeo", "evalset", "cron", "daily"],
  "priority": "P1",
  "enabled": true,
  "created_at": "2026-03-12",
  "notes": "评测标准版本从eval-standard-version.json动态读取，不硬编码"
}
