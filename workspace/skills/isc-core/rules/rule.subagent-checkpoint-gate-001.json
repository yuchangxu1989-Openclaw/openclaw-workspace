{
  "id": "rule.subagent-checkpoint-gate-001",
  "domain": "quality",
  "type": "rule",
  "scope": "isc",
  "priority": "critical",
  "enforcement_tier": "P0_gate",
  "description": "子Agent任务必须分段执行+分段验证。禁止单次长程任务（>5min或>20k tokens）不产出中间结果。",
  "rationale": "意图准确率子Agent连续两次跑10分钟耗尽token却零产出。根因是任务粒度过大，单Agent无法在token/时间限制内完成分析+修改+验证全流程。",
  "rule": {
    "requirements": [
      "复杂任务必须拆分为多个子步骤，每步有明确产出文件",
      "子Agent任务预估>5min或>15k tokens时，必须拆为2+个串行子Agent",
      "每个子Agent必须在结束前写入文件（报告/代码/数据），禁止仅返回对话结果",
      "分析和修改必须分离：先分析产出报告，再基于报告修改代码"
    ],
    "anti_patterns": [
      "单个子Agent同时做：读代码+分析问题+修改代码+跑测试+写报告",
      "子Agent执行完毕但result只有一句话（被截断的标志）"
    ]
  },
  "trigger": {
    "events": {
      "META": [
        "orchestration.task.created",
        "orchestration.task.timeout",
        "orchestration.task.truncated"
      ]
    },
    "actions": [
      {
        "type": "auto_trigger",
        "description": "执行规则检查"
      }
    ],
    "event": "orchestration.task.created"
  },
  "created_at": "2026-03-05T07:50:00+08:00",
  "version": "1.0.0",
  "action": {
    "type": "gate",
    "handler": "subagent-checkpoint-gate",
    "on_failure": "reject",
    "description": "创建子Agent时检查任务复杂度，超标则要求拆分",
    "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.subagent-checkpoint-gate-001.sh"
  },
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00",
  "enforcement": "programmatic",
  "fullchain_status": "expanded"
}
