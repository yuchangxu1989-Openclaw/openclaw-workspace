{
    "id": "rule.interactive-card-context-inference-001",
    "event_type": "session.reply.received",
    "description": "当收到用户回复引用的消息体为[Interactive Card]时，不得询问用户卡片内容。必须根据最近发出的消息、当前对话上下文推断卡片内容并直接响应。",
    "rule_name": "飞书卡片回复上下文推断",
    "version": "1.0.0",
    "severity": "medium",
    "trigger": {
        "events": [
            "session.reply.received"
        ],
        "condition": "replied_message.body contains '[Interactive Card]'",
        "actions": [
            {
                "type": "auto_trigger",
                "description": "收到引用[Interactive Card]的回复时，自动回溯最近5条消息推断卡片内容并直接响应",
                "behavior": "infer_card_context_and_respond"
            },
            {
                "type": "block-on-fail",
                "description": "禁止向用户反问卡片内容，必须自行推断",
                "behavior": "block_user_query_about_card"
            }
        ]
    },
    "action": {
        "type": "inference",
        "steps": [
            "回溯最近5条自己发出的消息",
            "匹配可能的卡片内容",
            "基于推断内容直接响应",
            "禁止向用户反问卡片内容"
        ],
        "handler": "interactive-card-context-inference",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.interactive-card-context-inference-001.sh"
    },
    "enforcement_tier": "P0_gate",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/interactive-card-context-inference.js",
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 rule.interactive-card-context-inference-001 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/interactive-card-context-inference.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/interactive-card-context-inference.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}