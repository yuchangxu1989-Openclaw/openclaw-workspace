{
  "type": "detection",
  "id": "N017",
  "name": "cras_recurring_pattern_auto_resolve",
  "description": "CRAS重复模式自动解决 - CRAS-B用户洞察分析发现同一问题模式≥2次时，主动根因分析并自动解决",
  "domain": "cognitive_reflection",
  "scope": "system-wide",
  "trigger": {
    "schedule": "0 */2 * * *",
    "command": "cd /root/.openclaw/workspace/skills/cras && node index.js --insight",
    "condition": "insight.recurring_patterns.length > 0",
    "events": {
      "L1": [
        "cras.pattern.detected",
        "cras.recurring.issue_identified",
        "detection.recurring.threshold_exceeded"
      ]
    }
  },
  "detection": {
    "source": "UserInsightHub.analyzeRecurringPatterns",
    "method": "analyze_recurring_patterns",
    "pattern_matching": {
      "fields": [
        "error_type",
        "failed_skill",
        "error_message_keyword"
      ],
      "time_window": "48h",
      "threshold": 2
    }
  },
  "governance": {
    "auto_execute": true,
    "priority": "MEDIUM",
    "risk_level": "medium"
  },
  "execution": {
    "type": "root_cause_and_fix",
    "steps": [
      {
        "order": 1,
        "action": "analyze_recurring_patterns",
        "executor": "cras/index.js",
        "method": "UserInsightHub.analyzeRecurringPatterns",
        "output": "recurring_patterns_report"
      },
      {
        "order": 2,
        "action": "auto_resolve_patterns",
        "executor": "infrastructure/pipeline/l3-pipeline.js",
        "method": "execute_auto_fix_for_patterns",
        "strategies": [
          {
            "pattern": "file_not_found",
            "fix": "auto_create_file"
          },
          {
            "pattern": "path_mismatch",
            "fix": "auto_update_reference"
          },
          {
            "pattern": "skill_not_loaded",
            "fix": "trigger_skill_reload"
          }
        ]
      },
      {
        "order": 3,
        "action": "mark_resolved",
        "executor": "cras/index.js",
        "method": "UserInsightHub.markPatternsResolved"
      }
    ]
  },
  "notification": {
    "on_complete": {
      "channel": "feishu",
      "format": "compact",
      "content": "CRAS重复模式分析完成，自动解决{resolved_count}个问题"
    }
  },
  "created_at": "2026-02-25T23:45:00Z",
  "updated_at": "2026-02-25T23:49:00Z",
  "version": "1.1.0",
  "status": "active",
  "enforcement_tier": "P1_process",
  "action": {
    "type": "auto",
    "handler": "cras/index.js",
    "on_failure": "retry",
    "description": "CRAS检测到重复模式时自动触发解决方案生成并执行"
  },
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}