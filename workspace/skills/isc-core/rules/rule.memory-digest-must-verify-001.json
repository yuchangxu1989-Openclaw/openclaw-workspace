{
    "id": "rule.memory-digest-must-verify-001",
    "event_type": "knowledge.general.updated",
    "description": "消化任何历史信息后必须核实磁盘文件实际存在。流程：记录→核实文件→补缺→commit。不能只写memory不查磁盘。",
    "rule_name": "记忆消化必须核实",
    "version": "1.0.0",
    "severity": "high",
    "category": "meta-governance",
    "trigger": {
        "events": [
            "knowledge.general.updated",
            "knowledge.general.created"
        ],
        "actions": [
            "quality.general.disk_check"
        ],
        "event": "knowledge.general.updated"
    },
    "conditions": {
        "workflow": [
            "record",
            "verify_file_exists",
            "fill_gaps",
            "git_commit"
        ],
        "forbidden": "memory_only_without_disk_verification"
    },
    "rationale": {
        "source": "用户教学",
        "user_quote": "你学到的东西，不应该像看电影一样只是增加了点记忆。记忆不值钱，很容易抹去。MEMORY是声明式的文字描述，真正执行起来会出现漂移。"
    },
    "enforcement_tier": "P1_check",
    "created_at": "2026-03-06T00:28:00+08:00",
    "action": {
        "type": "handler",
        "handler": "memory-digest-must-verify",
        "description": "",
        "script": "scripts/isc-hooks/rule.memory-digest-must-verify-001.sh"
    },
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/memory-digest-must-verify.js",
    "verification": {
        "method": "knowledge_integrity_check",
        "description": "验证知识规则 rule.memory-digest-must-verify-001 的存储和检索正确性",
        "assertions": [
            {
                "check": "data_persisted",
                "desc": "知识/记忆数据被正确持久化"
            },
            {
                "check": "retrieval_accurate",
                "desc": "检索结果与查询语义匹配"
            },
            {
                "check": "no_data_loss",
                "desc": "写入后读取数据无丢失"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/memory-digest-must-verify.js && echo 'handler_exists:pass'",
        "expected_outcome": "知识正确持久化且可准确检索",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}