{
  "id": "rule.vectorization.memory-auto-001",
  "name": "memory_mandatory_vectorization",
  "domain": "vectorization",
  "type": "rule",
  "scope": "memory",
  "description": "记忆必须向量化 - 所有记忆文件必须生成1024维智谱向量",
  "version": "1.0.0",
  "priority": 8,
  "condition": {
    "type": "file_exists",
    "path": "memory/{date}.md"
  },
  "requirement": {
    "vector_must_exist": true,
    "vector_dimension": 1024,
    "vector_engine": "zhipu-embedding-3",
    "vector_path": "infrastructure/vector-service/vectors/memory-{date}.json"
  },
  "auto_trigger": {
    "enabled": true,
    "on_events": [
      "memory.created"
    ],
    "action": "auto_vectorize",
    "handler": "/root/.openclaw/workspace/infrastructure/vector-service/vectorize.sh"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "severity": "warning"
  },
  "created_at": "2026-02-28T23:30:00+08:00",
  "updated_at": "2026-02-28T23:30:00+08:00",
  "trigger": {
    "events": [
      "isc:rule:matched",
      "isc:category:vectorization"
    ],
    "actions": [
      {
        "type": "log",
        "level": "info"
      }
    ]
  },
  "enforcement_tier": "P1_process"
}