{
    "id": "rule.intent-ruleify-consumption-001",
    "event_type": "intent.ruleify",
    "description": "当意图分析器识别出 ruleify 类意图时，路由到 intent-event-handler 创建 ISC 规则草案。确保 intent.ruleify 事件在 event-bus 链路中被正确匹配和执行。",
    "rule_name": "Intent Ruleify 消费路由",
    "version": "1.0.0",
    "severity": "high",
    "trigger": {
        "events": [
            "intent.ruleify"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "路由 intent.ruleify 到 intent-event-handler 进行规则草案创建"
            }
        ],
        "event": "intent.ruleify"
    },
    "action": {
        "type": "script",
        "script": "scripts/isc-hooks/rule.intent-ruleify-consumption-001.sh"
    },
    "enforcement_tier": "P0_blocking",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/intent-ruleify-consumption.js",
    "fullchain_status": "expanded",
    "verification": {
        "method": "intent_routing_check",
        "description": "验证意图路由规则 rule.intent-ruleify-consumption-001 的分发正确性",
        "assertions": [
            {
                "check": "intent_recognized",
                "desc": "目标意图被正确识别"
            },
            {
                "check": "route_correct",
                "desc": "意图被路由到正确的处理器"
            },
            {
                "check": "fallback_handled",
                "desc": "无法识别的意图有fallback处理"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/intent-ruleify-consumption.js && echo 'handler_exists:pass'",
        "expected_outcome": "意图准确识别并路由到正确处理器",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}