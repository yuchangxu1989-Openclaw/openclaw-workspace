{
    "id": "rule.naming-mece-consistency-001",
    "rule_id": "NAMING_MECE_CONSISTE",
    "event_type": "architecture.diagram.created",
    "name": "naming_mece_consistency_check",
    "description": "命名MECE校验——同一层级的所有实体关键词两两比对，不允许概念重叠",
    "priority": "P1",
    "domain": "quality",
    "type": "rule",
    "scope": "naming",
    "version": "1.0.0",
    "rationale": "命名重叠导致职责边界模糊，如战略家'任务编排'与DTO'任务编排'概念冲突",
    "governance": {
        "auto_execute": true,
        "councilRequired": false
    },
    "standard": {
        "scope": [
            "Agent定位描述",
            "规则命名",
            "事件命名",
            "技能命名"
        ],
        "method": "同一图/同一层级所有实体关键词两两比对，重叠即报错",
        "badcases": [
            {
                "case": "战略家'任务编排' vs 本地任务编排'任务编排'",
                "reason": "同层级概念重叠，职责边界不清",
                "fix": "战略家改为'战略决策与任务编排'，DTO改为'声明式任务调度'"
            }
        ],
        "rules": [
            {
                "id": "MECE1",
                "rule": "同一层级的所有实体关键词两两比对，不允许重叠"
            },
            {
                "id": "MECE2",
                "rule": "检测到重叠时，必须给出消歧建议并阻断提交"
            }
        ]
    },
    "trigger": {
        "events": [
            "architecture.diagram.created",
            "isc.rule.created",
            "skill.general.created"
        ],
        "actions": [
            "quality.naming.mece_check"
        ],
        "event": "architecture.diagram.created"
    },
    "enforcement_tier": "P1_process",
    "created_at": "2026-03-05",
    "source": "用户教学：命名MECE校验标准",
    "action": {
        "type": "script",
        "handler": "naming-convention-check",
        "script": "scripts/isc-hooks/rule.naming-mece-consistency-001.sh"
    },
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/naming-mece-consistency.js",
    "scoring_rubric": "handler可执行+逻辑匹配描述=60%; 事件订阅完整=20%; 测试覆盖=20%",
    "north_star_indicator": {
        "primary": "言出法随达成率",
