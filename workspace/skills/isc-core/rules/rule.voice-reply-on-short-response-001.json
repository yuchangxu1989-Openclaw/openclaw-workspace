{
  "id": "voice-reply-on-short-response-001",
  "name": "短回复自动语音回复",
  "description": "当用户发送语音消息且回复内容较短（<50字）时，自动使用GLM-TTS语音气泡回复",
  "priority": "P1",
  "trigger": {
    "event": "user.message.voice",
    "condition": "response_length < 50"
  },
  "action": {
    "handler": "feishu-voice-reply.sh",
    "params": {
      "voice": "douji",
      "trim_seconds": 2.0
    }
  },
  "tags": [
    "voice",
    "tts",
    "feishu",
    "ux"
  ],
  "handler": "cognitive-guard"
}
