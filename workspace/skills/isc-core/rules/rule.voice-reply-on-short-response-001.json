{
    "id": "rule.voice-reply-on-short-response-001",
    "event_type": "before_reply",
    "name": "短回复语音建议",
    "description": "当回复文本长度少于20字时，建议使用语音回复以增强表达效果。",
    "priority": 50,
    "version": "1.0.0",
    "enabled": true,
    "trigger": {
        "event": "before_reply",
        "condition": "text.length < 20",
        "events": [
            "isc.rule.voice.reply.on.short.response.001",
            "before_reply"
        ]
    },
    "action": {
        "type": "suggest",
        "suggestion": "reply_as_voice"
    },
    "handler": "skills/isc-core/handlers/voice-reply-on-short-response.js",
    "tags": [
        "voice",
        "ux",
        "reply-format"
    ],
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 rule.voice-reply-on-short-response-001 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/voice-reply-on-short-response.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/voice-reply-on-short-response.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}