{
  "type": "naming-standard",
  "id": "N006",
  "name": "skill_name_bilingual_display",
  "description": "技能名称双语展示标准 - 所有汇报涉及skill英文名时必须同时展示中文名",
  "scope": "skill-reports-and-outputs",
  "pattern": "英文名(中文名)",
  "regex": "^[a-z0-9-]+\\([\\u4e00-\\u9fa5]+\\)$",
  "example": "isc-core(智能标准中心), seef(技能生态进化工厂), cras(认知进化伙伴)",
  "required": true,
  "priority": "high",
  "category": "user_experience",
  "version": "1.0.0",
  "created_at": "2026-02-23T19:28:00Z",
  "status": "active",
  "trigger": {
    "events": {
      "L1": [
        "isc:rule:matched",
        "isc:category:user_experience"
      ]
    }
  },
  "enforcement_tier": "P1_process",
  "action": {
    "type": "monitor",
    "handler": "bilingual-display-checker",
    "on_failure": "warn",
    "description": "报告输出时检查技能名称是否包含双语展示，不符合则警告"
  },
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}