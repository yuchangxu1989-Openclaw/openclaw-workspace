{
    "id": "rule.layered-end-to-end-principle-001",
    "rule_name": "分层端到端原则",
    "version": "1.0.0",
    "severity": "critical",
    "description": "每个规则/任务/技能必须分三层解耦：感知层（谁在观察？用什么探针？）、认知层（谁在判断？）、执行层（谁在行动？）。三层通过事件总线解耦，任何一层替换不影响其他两层。",
    "category": "architecture",
    "trigger": {
        "events": ["architecture.decision.made", "isc.rule.created", "skill.created", "dto.task.created"],
        "actions": ["architecture.layered_check"]
    },
    "conditions": {
        "layers_required": ["perception", "cognition", "execution"],
        "decoupling": "event_bus",
        "replaceability": "any_layer_independent"
    },
    "rationale": {
        "source": "用户教学",
        "user_quote": "实际上都是要分层解耦的。我们不可能一步到位端到端，Agent一定是分层端到端。"
    },
    "enforcement_tier": "P0_gate",
    "created_at": "2026-03-06T00:28:00+08:00"
}
