{
    "id": "rule.intent-type-convergence-001",
    "event_type": "event.type.registration_requested",
    "description": "意图识别系统必须覆盖且仅覆盖5种收敛类型：(1)正负向情绪意图、(2)规则触发意图、(3)复杂意图（需5轮以上上下文推理）、(4)隐含意图（非明确表达，需推理）、(5)一句话多意图。任何新意图类型必须归入以上5类之一，否则不予注册。",
    "rule_name": "意图类型收敛标准",
    "version": "1.0.0",
    "severity": "high",
    "trigger": {
        "events": [
            "event.type.registration_requested"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "验证新意图类型归属，不属于5类则拒绝注册并要求MECE重分类"
            }
        ],
        "event": "event.type.registration_requested"
    },
    "action": {
        "type": "script",
        "script": "scripts/isc-hooks/rule.intent-type-convergence-001.sh"
    },
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/intent-type-convergence.js",
    "fullchain_status": "expanded",
    "verification": {
        "method": "intent_routing_check",
        "description": "验证意图路由规则 rule.intent-type-convergence-001 的分发正确性",
        "assertions": [
            {
                "check": "intent_recognized",
                "desc": "目标意图被正确识别"
            },
            {
                "check": "route_correct",
                "desc": "意图被路由到正确的处理器"
            },
            {
                "check": "fallback_handled",
                "desc": "无法识别的意图有fallback处理"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/intent-type-convergence.js && echo 'handler_exists:pass'",
        "expected_outcome": "意图准确识别并路由到正确处理器",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}