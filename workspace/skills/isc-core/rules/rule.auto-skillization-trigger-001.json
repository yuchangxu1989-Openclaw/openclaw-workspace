{
    "id": "rule.auto-skillization-trigger-001",
    "event_type": "isc.rule.matched",
    "name": "auto_skillization",
    "description": "自动技能化触发规则 - 技能质量分>=50时自动触发技能化流程",
    "priority": 9,
    "legacyId": "R001",
    "domain": "automation",
    "type": "rule",
    "scope": "skill",
    "condition": "skill_quality_score >= 50",
    "threshold": 50,
    "action": {
        "type": "script",
        "handler": "auto-skillization",
        "script": "scripts/isc-hooks/rule.auto-skillization-trigger-001.sh"
    },
    "governance": {
        "auto_execute": true,
        "councilRequired": false
    },
    "created_at": "2026-02-25T06:32:00+08:00",
    "version": "1.0.0",
    "trigger": {
        "events": [
            "isc.rule.matched",
            "isc.category.matched"
        ],
        "actions": [
            {
                "type": "log",
                "level": "info"
            }
        ],
        "event": "isc.rule.matched"
    },
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/auto-skillization.js",
    "fullchain_status": "complete",
    "plan": {
        "description": "自动技能化触发的执行计划",
        "steps": [
            {
                "step": 1,
                "action": "check_score",
                "desc": "确认技能质量分>=50达到技能化阈值"
            },
            {
                "step": 2,
                "action": "prepare_skill_meta",
                "desc": "生成技能元数据(名称、描述、输入输出)"
            },
            {
                "step": 3,
                "action": "create_skill_scaffold",
                "desc": "创建技能目录结构和SKILL.md"
            },
            {
                "step": 4,
                "action": "migrate_code",
                "desc": "将脚本代码迁移到技能handler"
            },
            {
                "step": 5,
                "action": "register_skill",
                "desc": "注册技能到技能库并发布"
            }
        ],
        "rollback": {
            "strategy": "cleanup_scaffold",
            "desc": "技能化失败时清理已创建的技能目录和注册记录"
        }
    },
    "verification": {
        "description": "验证技能化流程的完整性",
        "assertions": [
            {
                "check": "skill_dir_exists",
                "desc": "技能目录已创建且结构完整"
            },
            {
                "check": "skill_md_valid",
                "desc": "SKILL.md包含必要字段(名称、描述、输入输出)"
            },
            {
                "check": "handler_runnable",
                "desc": "技能handler可正常执行"
            }
        ],
        "metrics": [
            {
                "name": "skillization_success_rate",
                "desc": "技能化成功率"
            },
            {
                "name": "avg_skillization_time_s",
                "desc": "平均技能化耗时(秒)"
            }
        ],
        "timeout": 60
    }
}
