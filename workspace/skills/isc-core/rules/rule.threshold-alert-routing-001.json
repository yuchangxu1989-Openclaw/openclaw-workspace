{
    "id": "rule.threshold-alert-routing-001",
    "rule_id": "rule.threshold-alert-routing-001",
    "event_type": "isc.yellow_light.threshold_crossed",
    "description": "threshold-scanner 发射的4类阈值越界事件统一路由到 notify-alert handler。修复 P0-04：isc.yellow_light / eventbus.size / handler.failure / eventbus.backlog 四种 threshold_crossed 事件无消费路径。",
    "rule_name": "阈值越界告警路由",
    "version": "1.0.0",
    "severity": "high",
    "category": "monitoring",
    "trigger": {
        "events": [
            "isc.yellow_light.threshold_crossed",
            "system.eventbus.size_threshold_crossed",
            "system.handler.failure_threshold_crossed",
            "system.eventbus.backlog_threshold_crossed"
        ],
        "actions": [
            "threshold.alert.notify",
            "threshold.alert.log"
        ],
        "event": "isc.yellow_light.threshold_crossed"
    },
    "conditions": {
        "source": "threshold-scanner",
        "severity_mapping": {
            "isc.yellow_light.threshold_crossed": "warning",
            "system.eventbus.size_threshold_crossed": "critical",
            "system.handler.failure_threshold_crossed": "critical",
            "system.eventbus.backlog_threshold_crossed": "warning"
        }
    },
    "rationale": "reviewer审计发现 threshold-scanner 发射的4类事件全部无消费规则，告警触发后完全静默",
    "enforcement_tier": "P0_block",
    "created_at": "2026-03-06T18:45:00+08:00",
    "action": {
        "type": "handler",
        "handler": "notify-alert",
        "description": "阈值越界 → 写入 alerts.jsonl 供 heartbeat 读取",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.threshold-alert-routing-001.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/threshold-alert-routing.js",
    "scoring_rubric": {
        "completeness": 1,
        "handler_real": 1,
        "event_bound": 0.5,
        "test_covered": 0
    },
    "north_star_indicator": "认知层真实代码覆盖率",
    "gate_relevance": 0.6,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "event-routing",
    "verification": {
        "method": "detection_accuracy_check",
        "description": "验证检测规则 rule.threshold-alert-routing-001 的识别准确率",
        "assertions": [
            {
                "check": "true_positive",
                "desc": "目标模式被准确识别"
            },
            {
                "check": "false_positive_low",
                "desc": "误报率在可接受范围内"
            },
            {
                "check": "alert_delivered",
                "desc": "检测到问题后告警正确发送"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/threshold-alert-routing.js && echo 'handler_exists:pass'",
        "expected_outcome": "目标模式准确检测，误报率<5%",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}