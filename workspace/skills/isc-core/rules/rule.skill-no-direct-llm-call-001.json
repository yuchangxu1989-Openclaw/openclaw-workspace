{
  "id": "rule.skill-no-direct-llm-call-001",
  "name": "技能禁止直接调用LLM API",
  "description": "技能代码中禁止直接发HTTP请求调用LLM API（OpenAI/Anthropic/智谱等）。技能使用LLM能力的正确方式：(1)默认用当前Agent的模型直接执行 (2)需要多次独立LLM调用时通过sessions_spawn派子Agent。模型选择是运行时配置层的职责，不是技能的职责。除非用户显式指定某技能绑定某模型。",
  "version": "1.0.0",
  "priority": "P0",
  "category": "architecture",
  "trigger": {
    "events": [
      "skill.lifecycle.created",
      "skill.lifecycle.modified"
    ],
    "actions": [
      "quality.code.no_direct_llm_check"
    ],
    "event": "skill.lifecycle.created"
  },
  "conditions": {
    "forbidden_patterns": [
      "fetch.*chat/completions",
      "axios.*chat/completions",
      "https.request.*bigmodel",
      "https.request.*anthropic",
      "https.request.*openai"
    ],
    "allowed": "用户显式在配置中指定技能-模型绑定关系"
  },
  "rationale": "用户原话：'即便没有路由层，不也可以由默认模型来调度技能么？技能为什么一定要写指定的模型呢？'",
  "created_at": "2026-03-06T02:07:00+08:00",
  "action": {
    "type": "script",
    "script": "scripts/isc-hooks/rule.skill-no-direct-llm-call-001.sh"
  },
  "enforcement": "programmatic",
  "fullchain_status": "expanded",
  "handler": "skills/isc-core/handlers/skill-no-direct-llm-call.js",
  "rule_id": "rule.skill-no-direct-llm-call-001",
  "scoring_rubric": {
    "completeness": 1,
    "handler_real": 1,
    "event_bound": 0.5,
    "test_covered": 0
  },
  "north_star_indicator": "认知层真实代码覆盖率",
  "gate_relevance": 1,
  "process_indicators": [
    "handler_execution_count",
    "gate_pass_rate"
  ],
  "layer": "enforcement-gate"
}
