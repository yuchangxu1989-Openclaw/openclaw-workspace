{
  "id": "rule.seef-skill-registered-001",
  "name": "seef_skill_registered",
  "domain": "quality",
  "type": "automation",
  "description": "技能注册/更新时自动触发SEEF质量评估",
  "trigger": {
    "events": {
      "L1": [
        "skill.registered",
        "skill.updated"
      ]
    },
    "condition": "skill_path OR skillId"
  },
  "action": {
    "type": "auto",
    "skill": "seef",
    "subskill": "evaluator",
    "handler": "seef/evaluator",
    "on_failure": "warn"
  },
  "governance": {
    "auto_execute": true
  },
  "enforcement_tier": "P1_process",
  "created_at": "2026-03-05T03:00:00+08:00",
  "version": "1.0.0",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}