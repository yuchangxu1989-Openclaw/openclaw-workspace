{
  "id": "rule.seef-skill-registered-001",
  "name": "seef_skill_registered",
  "domain": "quality",
  "type": "automation",
  "description": "技能注册/更新时自动触发SEEF质量评估",
  "trigger": {
    "events": [
      "skill.general.created",
      "skill.general.updated"
    ],
    "condition": "skill_path OR skillId",
    "actions": [
      {
        "type": "auto_trigger",
        "description": "执行seef_skill_registered规则检查"
      }
    ]
  },
  "action": {
    "type": "skill",
    "skill": "seef",
    "subskill": "evaluator",
    "handler": "seef-skill-registered"
  },
  "governance": {
    "auto_execute": true
  },
  "enforcement_tier": "P1_process",
  "created_at": "2026-03-05T03:00:00+08:00",
  "version": "1.0.0"
}