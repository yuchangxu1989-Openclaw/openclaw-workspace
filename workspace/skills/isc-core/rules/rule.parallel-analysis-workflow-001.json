{
  "id": "rule.parallel-analysis-workflow-001",
  "name": "parallel_analysis_workflow",
  "domain": "analysis",
  "type": "workflow",
  "description": "并行分析工作流 - 同时执行多个分析任务提高效率",
  "trigger": {
    "type": "event",
    "events": [
      "cras.general.requested"
    ],
    "actions": [
      {
        "type": "auto_trigger",
        "description": "执行parallel_analysis_workflow规则检查"
      }
    ]
  },
  "orchestration": {
    "parallel": true,
    "maxConcurrency": 5,
    "aggregateResults": true
  },
  "action": {
    "workflow": [
      {
        "step": 1,
        "name": "需求分析",
        "module": "subagent",
        "task": "分析用户需求的核心要点"
      },
      {
        "step": 2,
        "name": "竞品调研",
        "module": "subagent",
        "task": "调研同类解决方案"
      },
      {
        "step": 3,
        "name": "技术评估",
        "module": "subagent",
        "task": "评估技术可行性"
      },
      {
        "step": 4,
        "name": "风险分析",
        "module": "subagent",
        "task": "识别潜在风险点"
      }
    ]
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false
  },
  "created_at": "2026-02-25T11:37:00+08:00",
  "version": "1.0.0"
}