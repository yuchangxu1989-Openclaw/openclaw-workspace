{
  "id": "rule.pipeline-benchmark-design-document-alignment-001",
  "name": "pipeline_benchmark_design_document_alignment",
  "domain": "architecture",
  "type": "rule",
  "version": "1.0.0",
  "description": "设计文档创建或修改时触发统一架构治理补充检查，补足 anti-entropy / layered / review 三类基础规则在 benchmark 事件命名下的命中。",
  "trigger": {
    "events": [
      "design.document.created",
      "design.document.modified"
    ],
    "event": "design.document.created"
  },
  "priority": "P1",
  "enforcement_tier": "P1_process",
  "action": {
    "type": "check",
    "handler": "architecture-review-pipeline"
  }
}
