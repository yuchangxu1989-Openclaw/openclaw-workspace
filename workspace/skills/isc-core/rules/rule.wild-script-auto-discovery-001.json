{
    "id": "ISC-WILD-SCRIPT-AUTO-DISCOVERY-001",
    "event_type": "cron.daily.0900",
    "name": "野生脚本自动发现与收编",
    "description": "每日自动扫描scripts/目录，发现不属于任何技能的脚本，告警并推动收编",
    "trigger": {
        "events": [
            "cron.daily.0900"
        ]
    },
    "condition": "scripts/目录下存在非薄封装的脚本文件",
    "action": "输出野生脚本清单到日志，新增脚本触发告警",
    "severity": "medium",
    "created": "2026-03-09",
    "handler": "skills/isc-core/handlers/wild-script-auto-discovery.js",
    "verification": {
        "method": "detection_accuracy_check",
        "description": "验证检测规则 ISC-WILD-SCRIPT-AUTO-DISCOVERY-001 的识别准确率",
        "assertions": [
            {
                "check": "true_positive",
                "desc": "目标模式被准确识别"
            },
            {
                "check": "false_positive_low",
                "desc": "误报率在可接受范围内"
            },
            {
                "check": "alert_delivered",
                "desc": "检测到问题后告警正确发送"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/wild-script-auto-discovery.js && echo 'handler_exists:pass'",
        "expected_outcome": "目标模式准确检测，误报率<5%",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}