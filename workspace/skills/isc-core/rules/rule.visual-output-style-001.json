{
  "id": "rule.visual-output-style-001",
  "rule_name": "工程图视觉规范",
  "version": "1.0.0",
  "severity": "medium",
  "description": "所有工程图（架构图、集成映射图、数据流图等）必须：1.浅色背景（白色或浅灰）2.中文标注（不接受纯英文）3.颜色柔和不刺眼。用户原话：'颜色轻一些，不要纯英文，我不想看纯英文'",
  "source": "2026-03-05 用户反馈",
  "trigger": {
    "events": {
      "L1": [
        "visual.diagram.generating"
      ]
    }
  },
  "action": {
    "type": "auto",
    "handler": "mermaid-style-enforcer",
    "on_failure": "retry",
    "description": "Mermaid渲染时强制应用：bgColor=ffffff, theme=default, 中文标注优先"
  },
  "enforcement_tier": "P1_process",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}