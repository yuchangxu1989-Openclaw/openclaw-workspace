{
    "id": "rule.visual-output-style-001",
    "event_type": "document.diagram.created",
    "description": "所有工程图（架构图、集成映射图、数据流图等）必须：1.浅色背景（白色或浅灰）2.中文标注（不接受纯英文）3.颜色柔和不刺眼。用户原话：'颜色轻一些，不要纯英文，我不想看纯英文'",
    "rule_name": "工程图视觉规范",
    "version": "1.0.0",
    "severity": "medium",
    "source": "2026-03-05 用户反馈",
    "trigger": {
        "events": [
            "document.diagram.created"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "可视化输出时自动应用个性化设计风格，拒绝通用AI审美"
            }
        ],
        "event": "document.diagram.created"
    },
    "action": {
        "type": "handler",
        "handler": "document-structure-check",
        "description": "Mermaid渲染时：bgColor=ffffff, theme=default, 所有节点文本中文优先（可附英文）, subgraph用浅色fill",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.visual-output-style-001.sh"
    },
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/visual-output-style.js",
    "verification": {
        "method": "architecture_principle_check",
        "description": "验证架构规则 rule.visual-output-style-001 的设计约束",
        "assertions": [
            {
                "check": "principle_codified",
                "desc": "架构原则有可验证的判定条件"
            },
            {
                "check": "violation_detectable",
                "desc": "违反架构原则的设计可被检测"
            },
            {
                "check": "remediation_path",
                "desc": "违规时有明确的修复路径"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/visual-output-style.js && echo 'handler_exists:pass'",
        "expected_outcome": "架构违规被检测，提供修复路径",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}