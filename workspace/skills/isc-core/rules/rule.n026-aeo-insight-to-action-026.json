{
  "type": "decision",
  "id": "rule.n026-aeo-insight-to-action-026",
  "name": "aeo_insight_to_action",
  "description": "AEO洞察到整改闭环 - 当问题频率达到阈值时，自动生成短期/中期/长期整改方案并跟踪执行",
  "domain": "quality_assurance",
  "scope": "system-wide",
  "trigger": {
    "events": [
      "aeo_issue_frequency_threshold_exceeded",
      "n020_analysis_completed"
    ],
    "condition": "issue_frequency >= 3 OR severity == 'high'",
    "actions": [
      {
        "type": "auto_trigger",
        "description": "将AEO洞察自动转化为可执行的改进行动项，分配到相关技能owner"
      }
    ]
  },
  "action_plan_generation": {
    "short_term": {
      "timeframe": "24h",
      "actions": [
        "prompt_engineering_fix",
        "configuration_tuning",
        "hot_patch_deployment"
      ],
      "verification": "immediate_retest"
    },
    "medium_term": {
      "timeframe": "1 week",
      "actions": [
        "training_data_augmentation",
        "test_case_expansion",
        "threshold_adjustment"
      ],
      "verification": "regression_test_suite"
    },
    "long_term": {
      "timeframe": "1 month",
      "actions": [
        "model_architecture_review",
        "skill_refactoring",
        "capability_enhancement"
      ],
      "verification": "comprehensive_evaluation"
    }
  },
  "tracking_mechanism": {
    "issue_id_tracking": "link_action_to_issue",
    "progress_updates": "daily_status_log",
    "completion_verification": "reevaluation_required",
    "user_notification": "notify_on_resolution"
  },
  "escalation_rules": {
    "auto_escalate": "if_no_progress_48h",
    "escalation_target": "council_of_seven",
    "manual_override": "user_can_force_priority"
  },
  "governance": {
    "auto_execute": true,
    "priority": "HIGH",
    "council_required": "for_long_term_actions"
  },
  "enforcement_tier": "P1_process",
  "action": {
    "type": "script",
    "handler": "eval-quality-check",
    "script": "scripts/isc-hooks/rule.n026-aeo-insight-to-action-026.sh"
  },
  "enforcement": "programmatic",
  "fullchain_status": "expanded",
  "handler": "skills/isc-core/handlers/n026-aeo-insight-to-action.js"
}
