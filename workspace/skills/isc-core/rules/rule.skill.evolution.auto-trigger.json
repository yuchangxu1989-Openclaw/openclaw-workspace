{
    "id": "skill.evolution.auto-trigger",
    "rule_id": "rule.skill.evolution.auto-trigger",
    "event_type": "skill.usage.pattern_detected",
    "name": "技能进化自动触发",
    "description": "技能变更时自动触发SEEF进化流水线",
    "priority": 5,
    "version": "1.0.0",
    "status": "active",
    "trigger": {
        "type": "event",
        "sources": [
            "skill.general.modified",
            "skill.general.created",
            "skill.general.published"
        ],
        "events": [
            "skill.usage.pattern_detected",
            "skill.performance.degraded",
            "skill.evolution.scheduled"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "技能使用模式变化或性能下降时自动触发技能进化流程"
            }
        ],
        "event": "skill.usage.pattern_detected"
    },
    "condition": {
        "autoTrigger": true,
        "minISCScore": 50,
        "excludePatterns": [
            "**/node_modules/**",
            "**/.git/**",
            "**/*.log"
        ]
    },
    "action": {
        "type": "orchestration.general.trigger",
        "target": "seef.evolution-pipeline",
        "parameters": {
            "immediate": false,
            "queueIfRunning": true
        },
        "handler": "skill-evolution-trigger",
        "script": "scripts/isc-hooks/skill.evolution.auto-trigger.sh"
    },
    "createdAt": "2026-03-01T00:00:00Z",
    "updatedAt": "2026-03-01T00:00:00Z",
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/skill.evolution.auto-trigger.js",
    "scoring_rubric": {
        "completeness": 1,
        "handler_real": 1,
        "event_bound": 0.5,
        "test_covered": 0
    },
    "north_star_indicator": "自主闭环率",
    "gate_relevance": 0.6,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "automation-hook",
    "verification": {
        "method": "automation_trigger_check",
        "description": "验证自动化规则 skill.evolution.auto-trigger 的触发和执行链路",
        "assertions": [
            {
                "check": "trigger_event_subscribed",
                "desc": "事件订阅已注册: skill.usage.pattern_detected, skill.performance.degraded, skill.evolution.scheduled"
            },
            {
                "check": "handler_executable",
                "desc": "Handler可执行: skills/isc-core/handlers/skill.evolution.auto-trigger.js"
            },
            {
                "check": "output_generated",
                "desc": "触发后产出符合预期的输出"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/skill.evolution.auto-trigger.js && echo 'handler_exists:pass'",
        "expected_outcome": "事件触发后自动执行，产出正确输出",
        "timeout_seconds": 30,
        "on_failure": "block_and_alert"
    }
}