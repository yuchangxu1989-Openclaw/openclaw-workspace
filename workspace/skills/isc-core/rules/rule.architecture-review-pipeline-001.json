{
    "id": "rule.architecture-review-pipeline-001",
    "event_type": "document.document.created",
    "description": "任何架构设计方案或模块重构方案，必须经过标准化评审流水线：架构师出方案→工程师验证可落地性→质量分析师验证合理性→循环修复直到双通过→裁决殿终审→用户最终裁决。",
    "rule_name": "架构优化与模块重构评审流水线",
    "version": "1.0.0",
    "severity": "critical",
    "source": "2026-03-04 ISC-事件-DTO闭环设计过程中形成的实战流程",
    "trigger": {
        "events": [
            "document.document.created",
            "document.document.modified",
            "architecture.refactor.proposed",
            "skill.restructure.proposed",
            "system.failure.refactor_required"
        ],
        "actions": [
            {
                "type": "gate-check",
                "description": "架构方案必须经过标准化评审流水线：架构师出方案→工程师验证→质量分析师验证→裁决殿终审",
                "behavior": "enforce_review_pipeline"
            },
            {
                "type": "block-on-fail",
                "description": "跳过任何评审阶段的架构方案不得进入实施阶段",
                "behavior": "block_unreviewed_architecture"
            }
        ],
        "event": "document.document.created"
    },
    "action": {
        "type": "pipeline",
        "stages": [
            {
                "stage": "architect_design",
                "role": "系统架构师",
                "thinking": "high",
                "output": "designs/{topic}-v{version}.md",
                "pass_condition": "文档完整，无缺失章节"
            },
            {
                "stage": "parallel_review",
                "roles": [
                    "开发工程师",
                    "质量分析师"
                ],
                "thinking": "high",
                "parallel": true,
                "output": "reports/{topic}-{role}-review.md",
                "pass_condition": "工程师：0致命+0严重风险；质量分析师：评分≥用户标准"
            },
            {
                "stage": "fix_loop",
                "description": "复审不通过→打回架构师→修复→再复审，循环直到通过",
                "max_iterations": 5,
                "escalation": "超过5次循环→裁决殿介入诊断根因"
            },
            {
                "stage": "caijuedian_tribunal",
                "role": "裁决殿",
                "description": "7位神官独立视角battle，终审裁决",
                "pass_condition": "多数通过",
                "thinking": "high"
            },
            {
                "stage": "user_final_decision",
                "role": "用户",
                "description": "用户是最终裁决者，裁决殿是帮用户把关的"
            }
        ],
        "handler": "architecture-review"
    },
    "enforcement": "runtime_binding",
    "anti_entropy": "此规则本身是对评审流程的固化，防止未来退化为'架构师直出→用户看'的简化流程",
    "enforcement_tier": "P0_gate",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/architecture-review-pipeline.js",
    "verification": {
        "method": "automation_trigger_check",
        "description": "验证自动化规则 rule.architecture-review-pipeline-001 的触发和执行链路",
        "assertions": [
            {
                "check": "trigger_event_subscribed",
                "desc": "事件订阅已注册: document.document.created, document.document.modified, architecture.refactor.proposed"
            },
            {
                "check": "handler_executable",
                "desc": "Handler可执行: skills/isc-core/handlers/architecture-review-pipeline.js"
            },
            {
                "check": "output_generated",
                "desc": "触发后产出符合预期的输出"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/architecture-review-pipeline.js && echo 'handler_exists:pass'",
        "expected_outcome": "事件触发后自动执行，产出正确输出",
        "timeout_seconds": 30,
        "on_failure": "block_and_alert"
    }
}