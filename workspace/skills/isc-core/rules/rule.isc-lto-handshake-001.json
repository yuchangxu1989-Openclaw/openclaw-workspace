{
    "id": "rule.isc-lto-handshake-001",
    "event_type": "isc.rule.matched",
    "name": "isc_dto_periodic_handshake",
    "description": "ISC-DTO定期握手机制 - 每30分钟互相扫描对齐",
    "domain": "process",
    "type": "rule",
    "scope": "system",
    "rationale": "确保ISC规则变更后DTO能及时订阅，保持双向对齐",
    "governance": {
        "auto_execute": true,
        "councilRequired": false
    },
    "handshake": {
        "frequency": "30分钟",
        "cron": "*/30 * * * *",
        "initiator": "ISC",
        "responder": "本地任务编排",
        "steps": [
            "ISC扫描所有规则",
            "DTO扫描所有订阅",
            "双向对齐检查",
            "自动修复不对齐",
            "生成对齐报告"
        ]
    },
    "alert_conditions": {
        "alignment_rate_below": "90%",
        "action": "立即通知并自动修复"
    },
    "created_at": "2026-02-25T06:30:00+08:00",
    "version": "1.0.0",
    "trigger": {
        "events": [
            "isc.rule.matched",
            "isc.category.matched"
        ],
        "actions": [
            {
                "type": "log",
                "level": "info"
            }
        ],
        "event": "isc.rule.matched"
    },
    "enforcement_tier": "P1_process",
    "action": {
        "handler": "isc-lto-handshake",
        "type": "script",
        "script": "scripts/isc-hooks/rule.isc-lto-handshake-001.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/isc-lto-handshake.js",
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 rule.isc-lto-handshake-001 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/isc-lto-handshake.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/isc-lto-handshake.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}