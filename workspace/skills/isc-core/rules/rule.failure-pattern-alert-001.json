{
    "id": "rule.failure-pattern-alert-001",
    "event_type": "system.failure.pattern_detected",
    "name": "故障模式告警",
    "description": "检测到系统故障模式时触发告警通知",
    "version": "1.0.0",
    "severity": "critical",
    "trigger": {
        "events": [
            "system.failure.pattern_detected"
        ],
        "event": "system.failure.pattern_detected"
    },
    "action": {
        "type": "script",
        "handler": "notify-alert",
        "script": "scripts/isc-hooks/rule.failure-pattern-alert-001.sh"
    },
    "created_at": "2026-03-06",
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/failure-pattern-alert.js",
    "verification": {
        "method": "detection_accuracy_check",
        "description": "验证检测规则 rule.failure-pattern-alert-001 的识别准确率",
        "assertions": [
            {
                "check": "true_positive",
                "desc": "目标模式被准确识别"
            },
            {
                "check": "false_positive_low",
                "desc": "误报率在可接受范围内"
            },
            {
                "check": "alert_delivered",
                "desc": "检测到问题后告警正确发送"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/failure-pattern-alert.js && echo 'handler_exists:pass'",
        "expected_outcome": "目标模式准确检测，误报率<5%",
        "timeout_seconds": 30,
        "on_failure": "block_and_alert"
    }
}