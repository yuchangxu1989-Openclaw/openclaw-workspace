{
  "rule_id": "rule.project-mgmt-lesson-capture-001",
  "name": "项目管理经验沉淀门禁",
  "version": "1.0.0",
  "priority": "P1",
  "type": "gate",
  "description": "Sprint结束或项目里程碑完成时，必须沉淀经验教训和指标数据",
  "trigger": {
    "events": [
      "sprint.completed",
      "sprint.aborted",
      "project.milestone.reached",
      "review.rejected.count >= 2",
      "task.overdue.ratio > 0.5",
      "user.process.correction"
    ],
    "event": "sprint.completed"
  },
  "conditions": {
    "required_outputs": [
      {
        "type": "lesson",
        "path": "skills/project-mgmt/lessons/YYYY-MM-DD-{sprint}.md",
        "fields": [
          "目标vs实际",
          "做对了什么",
          "做错了什么",
          "流程改进点"
        ]
      },
      {
        "type": "metrics",
        "path": "skills/project-mgmt/metrics/YYYY-MM.json",
        "fields": [
          "planned_days",
          "actual_days",
          "tasks_total",
          "tasks_completed",
          "review_rejections",
          "parallel_ratio"
        ]
      }
    ],
    "anti_pattern_check": {
      "path": "skills/project-mgmt/lessons/anti-patterns.md",
      "action": "同类教训出现2次自动提炼为反模式条目"
    }
  },
  "actions": {
    "on_lesson_captured": [
      "检查是否有重复教训 → 升级为SKILL.md规则",
      "更新反模式库",
      "写入metrics指标"
    ],
    "on_user_correction": [
      "立即更新project-mgmt/SKILL.md",
      "记录为最高优先级反模式"
    ],
    "on_gate_fail": "阻止Sprint标记为完成，提醒补齐经验沉淀"
  },
  "rationale": {
    "source": "用户教学",
    "principle": "项目管理能力必须持续成长，不是静态流程文档",
    "anti_entropy": "每次执行都产生可复用知识，系统有序度递增"
  },
  "action": {
    "type": "handler",
    "handler": "report-snapshot",
    "description": "",
    "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.project-mgmt-lesson-capture-001.sh"
  },
  "enforcement": "programmatic"
}