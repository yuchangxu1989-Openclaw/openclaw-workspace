{
  "id": "rule.skill-must-use-llm-context-001",
  "name": "技能必须通过llm-context接口调用LLM",
  "version": "1.0.0",
  "description": "技能代码中不允许直接出现Provider URL或模型名称的硬编码。所有LLM调用必须通过 infrastructure/llm-context 标准接口进行，实现技能与模型的彻底解耦。",
  "category": "architecture",
  "severity": "error",
  "enabled": true,
  "trigger": {
    "events": [
      "skill.lifecycle.created",
      "skill.lifecycle.modified"
    ],
    "conditions": [
      {
        "type": "file_pattern",
        "pattern": "**/*.js",
        "description": "扫描所有JS文件"
      }
    ]
  },
  "check": {
    "type": "content_scan",
    "forbidden_patterns": [
      {
        "pattern": "open\\.bigmodel\\.cn",
        "description": "禁止硬编码智谱API地址"
      },
      {
        "pattern": "api\\.anthropic\\.com",
        "description": "禁止硬编码Anthropic API地址"
      },
      {
        "pattern": "api\\.openai\\.com",
        "description": "禁止硬编码OpenAI API地址"
      },
      {
        "pattern": "boom\\.aihuige\\.com",
        "description": "禁止硬编码Boom API地址"
      },
      {
        "pattern": "penguinsaichat\\.dpdns\\.org",
        "description": "禁止硬编码Penguinsaichat API地址"
      }
    ],
    "exemptions": [
      "infrastructure/llm-context/**",
      "skills/zhipu-keys/**",
      "tests/**",
      "**/SKILL.md",
      "**/*.md",
      "**/*.json"
    ],
    "required_import": {
      "pattern": "require.*infrastructure/llm-context|from.*infrastructure/llm-context",
      "description": "使用LLM时必须通过 infrastructure/llm-context 导入"
    }
  },
  "action": {
    "type": "block",
    "handler": "handlers/document-structure-check.js",
    "message": "❌ 违规：技能代码中检测到硬编码的LLM Provider URL或API Key。请使用 infrastructure/llm-context 标准接口调用LLM。\n\n正确用法：\nconst llm = require('路径/infrastructure/llm-context');\nconst result = await llm.chat(messages, { capability: 'chat' });",
    "auto_fix_hint": "将直接的 fetch/https 调用替换为 require('infrastructure/llm-context').chat()"
  },
  "metadata": {
    "created": "2026-03-06",
    "author": "战略家",
    "rationale": "技能与模型解耦是系统反熵增的关键架构决策。硬编码Provider信息导致：1)密钥泄露风险 2)Provider切换时需改所有技能 3)无法自动fallback 4)无法统一监控LLM调用",
    "related_infrastructure": "infrastructure/llm-context/",
    "tags": [
      "architecture",
      "llm",
      "decoupling",
      "security"
    ]
  }
}