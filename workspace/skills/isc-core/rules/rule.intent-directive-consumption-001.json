{
    "id": "rule.intent-directive-consumption-001",
    "event_type": "intent.directive",
    "description": "当意图分析器识别出 directive 类意图时，路由到 intent-event-handler 创建 本地任务编排 任务。确保 intent.directive 事件在 event-bus 链路中被正确匹配和执行。",
    "rule_name": "Intent Directive 消费路由",
    "version": "1.0.0",
    "severity": "high",
    "trigger": {
        "events": [
            "intent.directive"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "路由 intent.directive 到 intent-event-handler 创建 本地任务编排 任务"
            }
        ],
        "event": "intent.directive"
    },
    "action": {
        "type": "script",
        "script": "scripts/isc-hooks/rule.intent-directive-consumption-001.sh"
    },
    "enforcement_tier": "P0_blocking",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/intent-directive-consumption.js",
    "fullchain_status": "expanded",
    "verification": {
        "method": "orchestration_flow_check",
        "description": "验证编排规则 rule.intent-directive-consumption-001 的调度正确性",
        "assertions": [
            {
                "check": "dispatch_target_valid",
                "desc": "调度目标Agent/处理器有效"
            },
            {
                "check": "task_routed_correctly",
                "desc": "任务被路由到正确的执行者"
            },
            {
                "check": "result_collected",
                "desc": "执行结果被正确收集和报告"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/intent-directive-consumption.js && echo 'handler_exists:pass'",
        "expected_outcome": "任务正确调度到目标执行者并收集结果",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}