{
  "rule_id": "rule.task-orchestration-quality-001",
  "rule_name": "任务编排质量门禁",
  "description": "Agent任务拆解与协同模式是影响效率的关键。每次任务编排决策必须检查：并行度是否最大化、依赖关系是否真实、任务描述是否精确到一次完成。",
  "schema_version": "2.0",
  "severity": "high",
  "category": "orchestration",
  "trigger": {
    "events": [
      "orchestration.task.completed",
      "orchestration.subagent.created",
      "orchestration.task.sequential_detected",
      "orchestration.efficiency.throughput_below_expected",
      "orchestration.subagent.rework_triggered"
    ]
  },
  "action": {
    "type": "audit",
    "handler": "eval-quality-check",
    "checks": [
      {
        "id": "max_parallelism",
        "description": "无真实依赖的任务是否全部并行？串行执行无依赖任务=效率浪费",
        "fail_action": "warn"
      },
      {
        "id": "real_dependency",
        "description": "声称的依赖关系是否真实？'等A完成再做B'的A产出是否真的是B的输入？",
        "fail_action": "warn"
      },
      {
        "id": "task_precision",
        "description": "任务描述是否精确到子Agent一次完成？模糊任务导致返工=效率损失",
        "fail_action": "warn"
      },
      {
        "id": "granularity_optimal",
        "description": "拆分粒度是否最优？太粗→无法并行，太细→协调开销大",
        "fail_action": "warn"
      },
      {
        "id": "rework_prevention",
        "description": "是否预判了可能的返工点？选型决策、技术方案是否在任务描述中明确，避免子Agent自行选错",
        "fail_action": "warn"
      }
    ],
    "on_failure": "warn",
    "quality_analyst_report_fields": [
      "任务总数",
      "并行组数",
      "串行等待点及理由",
      "任务描述精确度评分",
      "预计vs实际返工次数"
    ],
    "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.task-orchestration-quality-001.sh"
  },
  "examples": [
    {
      "scenario": "ISC治理3个子任务并行拆解",
      "result": "APPROVE",
      "reason": "去重、门禁、schema迁移三者无依赖，正确并行"
    },
    {
      "scenario": "等ISC治理全部完成后才启动Day2验证",
      "result": "WARN",
      "reason": "ISC治理和Day2交付验证无强依赖，应同时推进"
    },
    {
      "scenario": "去重门禁任务未指定用LLM还是关键词匹配",
      "result": "WARN",
      "reason": "选型决策未在任务描述中明确，导致子Agent用Jaccard→返工→再返工，3轮浪费"
    },
    {
      "scenario": "意图修复拆4轮串行（分析→修复→再分析→再修复）",
      "result": "WARN",
      "reason": "分析和修复可合并为一个精确任务，或分析后一步到位修复，不应迭代试错"
    }
  ],
  "metadata": {
    "created": "2026-03-05",
    "source": "用户指出Agent编排模式是效率关键",
    "anti_entropy": true
  },
  "enforcement": "programmatic",
  "handler": "skills/isc-core/handlers/task-orchestration-quality.js",
  "id": "TASK-ORCHESTRATION-QUALITY-001",
  "scoring_rubric": {
    "completeness": 1,
    "handler_real": 1,
    "event_bound": 0.5,
    "test_covered": 0
  },
  "north_star_indicator": "言出法随达成率",
  "gate_relevance": 0.6,
  "process_indicators": [
    "handler_execution_count",
    "gate_pass_rate"
  ],
  "layer": "operational-rule"
}
