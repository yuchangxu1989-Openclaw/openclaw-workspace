{
    "id": "rule.isc-rule-modified-dedup-scan-001",
    "event_type": "isc.rule.modified",
    "name": "规则修改去重扫描",
    "description": "ISC规则修改后触发去重扫描，检测是否与其他规则产生重复",
    "version": "1.0.0",
    "trigger": {
        "events": [
            "isc.rule.modified"
        ],
        "event": "isc.rule.modified"
    },
    "action": {
        "type": "script",
        "handler": "dedup-scan",
        "script": "scripts/isc-hooks/rule.isc-rule-modified-dedup-scan-001.sh"
    },
    "created_at": "2026-03-06",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/isc-rule-modified-dedup-scan.js",
    "verification": {
        "method": "detection_accuracy_check",
        "description": "验证检测规则 rule.isc-rule-modified-dedup-scan-001 的识别准确率",
        "assertions": [
            {
                "check": "true_positive",
                "desc": "目标模式被准确识别"
            },
            {
                "check": "false_positive_low",
                "desc": "误报率在可接受范围内"
            },
            {
                "check": "alert_delivered",
                "desc": "检测到问题后告警正确发送"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/isc-rule-modified-dedup-scan.js && echo 'handler_exists:pass'",
        "expected_outcome": "目标模式准确检测，误报率<5%",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}