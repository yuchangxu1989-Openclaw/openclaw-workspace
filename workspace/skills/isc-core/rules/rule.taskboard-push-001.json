{
    "id": "ISC-TASKBOARD-PUSH-001",
    "rule_id": "rule.taskboard-push-001",
    "event_type": "user_asks_task_status",
    "name": "看板必须推给用户",
    "description": "show-task-board.sh只是自己看，用户看不到=没做。必须用show-task-board-feishu.sh生成格式化文本并发送给用户。",
    "trigger": {
        "events": [
            "user_asks_task_status",
            "batch_tasks_completed_gte_3",
            "any_task_failed",
            "new_task_wave_dispatched"
        ]
    },
    "action": {
        "type": "script",
        "command": "bash /root/.openclaw/workspace/scripts/show-task-board-feishu.sh",
        "deliver_to": "user_channel"
    },
    "severity": "high",
    "enforcement": "mandatory",
    "created": "2026-03-08",
    "rationale": "用户在飞书端看不到任何本地exec的输出，看板必须通过消息推送才能让用户可见。自己exec看=口嗨。",
    "handler": "skills/isc-core/handlers/taskboard-push-001.js",
    "scoring_rubric": {
        "completeness": 1.0,
        "handler_real": 1.0,
        "event_bound": 0.5,
        "test_covered": 0.0
    },
    "north_star_indicator": "言出法随达成率",
    "gate_relevance": 0.6,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "operational-rule",
    "verification": {
        "method": "convention_compliance_check",
        "description": "验证规范规则 ISC-TASKBOARD-PUSH-001 的一致性检查",
        "assertions": [
            {
                "check": "naming_pattern_enforced",
                "desc": "命名/格式规范有明确的正则或模式"
            },
            {
                "check": "violation_detected",
                "desc": "不符合规范的输入被检测到"
            },
            {
                "check": "correction_suggested",
                "desc": "违规时给出修正建议"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/taskboard-push-001.js && echo 'handler_exists:pass'",
        "expected_outcome": "不符合规范的命名/格式被检测并建议修正",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}