{
  "id": "rule.vectorization.unified-standard-001",
  "name": "unified_zhipu_vectorization_standard",
  "domain": "vectorization",
  "type": "standard",
  "scope": "global",
  "description": "统一使用智谱向量化标准 - 禁止TF-IDF，强制使用智谱Embedding API(1024维)",
  "version": "2.0.0",
  "priority": 10,
  
  "standard": {
    "engine": "zhipu",
    "model": "embedding-3",
    "dimension": 1024,
    "api_url": "open.bigmodel.cn",
    "batch_size": 5,
    "deprecated_engines": ["tfidf", "bge-m3", "local"]
  },
  
  "prohibited": {
    "tfidf_enabled": false,
    "local_embedding": false,
    "mixed_vector_types": false
  },
  
  "migration": {
    "from": "1.0.0",
    "changes": [
      "TF-IDF已废弃，所有向量必须重新生成",
      "向量维度统一为1024",
      "所有向量化通过智谱API完成"
    ],
    "deadline": "2026-03-01T00:00:00+08:00"
  },
  
  "auto_trigger": {
    "enabled": true,
    "scan_interval": "6h",
    "action": "enforce_standard",
    "cleanup_deprecated": true
  },
  
  "governance": {
    "auto_execute": true,
    "councilRequired": false,
    "severity": "error"
  },
  
  "created_at": "2026-02-28T23:30:00+08:00",
  "updated_at": "2026-02-28T23:30:00+08:00"
}
