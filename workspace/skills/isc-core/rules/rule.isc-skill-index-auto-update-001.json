{
  "id": "rule.isc-skill-index-auto-update-001",
  "name": "isc_skill_index_auto_update",
  "domain": "automation",
  "type": "rule",
  "scope": "system",
  "description": "技能索引自动更新 - 技能创建/修改/删除时自动更新CAPABILITY-ANCHOR.md",
  "rationale": "确保技能索引始终与实际情况一致，便于快速查找",
  "trigger": {
    "events": [
      "skill.general.created",
      "skill.general.updated",
      "skill.general.deleted",
      "isc.skill_index.refresh_requested"
    ],
    "condition": "skill_path OR skill_name OR skill_id",
    "actions": [
      {
        "type": "auto_trigger",
        "description": "技能变更时自动更新ISC技能索引，保持索引与实际技能一致"
      }
    ]
  },
  "action": {
    "type": "auto_update_index",
    "output": "/root/.openclaw/workspace/CAPABILITY-ANCHOR.md",
    "handler": "isc-skill-index-update"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false
  },
  "created_at": "2026-02-25T15:13:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P1_process"
}
