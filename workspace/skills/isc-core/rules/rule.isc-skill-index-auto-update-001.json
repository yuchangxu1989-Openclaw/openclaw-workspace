{
  "id": "rule.isc-skill-index-auto-update-001",
  "name": "isc_skill_index_auto_update",
  "domain": "automation",
  "type": "rule",
  "scope": "system",
  "description": "技能索引自动更新 - 技能创建/修改/删除时自动更新SKILL_INDEX.md",
  "rationale": "确保技能索引始终与实际情况一致，便于快速查找",
  "trigger": {
    "events": {
      "L1": [
        "skill.created",
        "skill.updated",
        "skill.deleted",
        "isc.skill.index.refresh_requested"
      ]
    },
    "condition": "skill_path OR skill_name OR skill_id"
  },
  "action": {
    "type": "auto_update_index",
    "output": "/root/.openclaw/workspace/SKILL_INDEX.md",
    "handler": "isc-skill-index",
    "on_failure": "retry"
  },
  "governance": {
    "auto_execute": true,
    "councilRequired": false
  },
  "created_at": "2026-02-25T15:13:00+08:00",
  "version": "1.0.0",
  "enforcement_tier": "P1_process",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}