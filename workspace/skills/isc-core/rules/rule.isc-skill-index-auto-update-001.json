{
    "id": "rule.isc-skill-index-auto-update-001",
    "event_type": "skill.general.created",
    "name": "isc_skill_index_auto_update",
    "description": "技能索引自动更新 - 技能创建/修改/删除时自动更新CAPABILITY-ANCHOR.md",
    "domain": "automation",
    "type": "rule",
    "scope": "system",
    "rationale": "确保技能索引始终与实际情况一致，便于快速查找",
    "trigger": {
        "events": [
            "skill.general.created",
            "skill.general.updated",
            "skill.general.deleted",
            "isc.skill_index.refresh_requested"
        ],
        "condition": "skill_path OR skill_name OR skill_id",
        "actions": [
            {
                "type": "auto_trigger",
                "description": "技能变更时自动更新ISC技能索引，保持索引与实际技能一致"
            }
        ]
    },
    "action": {
        "type": "script",
        "output": "/root/.openclaw/workspace/CAPABILITY-ANCHOR.md",
        "handler": "isc-skill-index-update",
        "script": "scripts/isc-hooks/rule.isc-skill-index-auto-update-001.sh"
    },
    "governance": {
        "auto_execute": true,
        "councilRequired": false
    },
    "created_at": "2026-02-25T15:13:00+08:00",
    "version": "1.0.0",
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/isc-skill-index-auto-update.js",
    "verification": {
        "method": "skill_lifecycle_check",
        "description": "验证技能生命周期规则 rule.isc-skill-index-auto-update-001 的管控能力",
        "assertions": [
            {
                "check": "lifecycle_event_captured",
                "desc": "技能创建/发布/更新事件被捕获"
            },
            {
                "check": "quality_gate_applied",
                "desc": "生命周期操作通过质量门禁"
            },
            {
                "check": "registry_updated",
                "desc": "技能注册表状态同步更新"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/isc-skill-index-auto-update.js && echo 'handler_exists:pass'",
        "expected_outcome": "技能生命周期事件被正确管控",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}