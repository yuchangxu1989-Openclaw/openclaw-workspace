{
    "id": "rule.board-push-on-task-complete-001",
    "event_type": "task.status.completed",
    "name": "任务完成时自动推送看板",
    "description": "当子Agent任务完成/超时/失败时，自动触发飞书看板推送，确保用户实时看到最新状态",
    "priority": "P1",
    "version": "1.0.0",
    "domain": "operations",
    "category": "board",
    "trigger": {
        "events": [
            "task.status.completed",
            "task.status.done",
            "task.status.timeout",
            "task.status.failed",
            "subagent.session.completed"
        ],
        "event": "task.status.completed"
    },
    "conditions": {},
    "action": {
        "handler": "board-push-on-complete",
        "type": "handler",
        "description": "异步调用 push-board-now.js，内置 content-hash 去重"
    },
    "created_at": "2026-03-11T19:50:00+08:00",
    "created_by": "fix-board-auto-push-v2",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/board-push-on-task-complete.js",
    "verification": {
        "method": "automation_trigger_check",
        "description": "验证自动化规则 rule.board-push-on-task-complete-001 的触发和执行链路",
        "assertions": [
            {
                "check": "trigger_event_subscribed",
                "desc": "事件订阅已注册: task.status.completed, task.status.done, task.status.timeout"
            },
            {
                "check": "handler_executable",
                "desc": "Handler可执行: skills/isc-core/handlers/board-push-on-task-complete.js"
            },
            {
                "check": "output_generated",
                "desc": "触发后产出符合预期的输出"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/board-push-on-task-complete.js && echo 'handler_exists:pass'",
        "expected_outcome": "事件触发后自动执行，产出正确输出",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}