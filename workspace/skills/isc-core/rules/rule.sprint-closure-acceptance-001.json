{
    "id": "SPRINT-CLOSURE-ACCEPTANCE-001",
    "rule_id": "rule.sprint-closure-acceptance-001",
    "event_type": "sprint.closure.requested",
    "name": "Sprint收工验收门禁",
    "description": "Sprint/Day标记完成前，必须通过四重验收：产物核查、指标采集、经验沉淀、裁决殿裁决。缺任何一项不允许close。",
    "priority": "P0",
    "version": "1.0.0",
    "type": "gate",
    "enforcement_tier": "P0_block",
    "domain": "project-mgmt",
    "scope": "sprint",
    "rationale": "Sprint结束时经常跳过经验沉淀和指标采集，导致项目管理能力不增长。此门禁强制四重验收。",
    "trigger": {
        "events": [
            "sprint.closure.requested",
            "sprint.day.closure.requested",
            "project.milestone.closure.requested"
        ],
        "actions": [
            {
                "type": "gate",
                "description": "执行四重验收门禁"
            }
        ],
        "event": "sprint.closure.requested"
    },
    "conditions": {
        "four_gates": [
            {
                "id": "artifact_audit",
                "name": "产物核查",
                "description": "所有标记完成的任务必须通过 rule.project-artifact-gate-001",
                "fail_action": "block"
            },
            {
                "id": "metrics_collected",
                "name": "指标采集",
                "description": "Sprint指标必须写入 skills/project-mgmt/metrics/YYYY-MM.json",
                "required_fields": [
                    "planned_days",
                    "actual_days",
                    "tasks_total",
                    "tasks_completed",
                    "review_rejections",
                    "parallel_ratio"
                ],
                "fail_action": "block"
            },
            {
                "id": "lessons_captured",
                "name": "经验沉淀",
                "description": "经验教训必须写入 skills/project-mgmt/lessons/YYYY-MM-DD-{sprint}.md",
                "required_sections": [
                    "目标vs实际",
                    "做对了什么",
                    "做错了什么",
                    "流程改进点"
                ],
                "fail_action": "block"
            },
            {
                "id": "tribunal_verdict",
                "name": "裁决殿裁决",
                "description": "必须有裁决殿裁决结果（通过/有条件通过/打回）",
                "fail_action": "warn_with_escalation"
            }
        ]
    },
    "actions": {
        "on_all_pass": [
            "emit sprint.closure.approved 事件",
            "更新PROJECT-TRACKER Sprint状态",
            "触发anti-pattern扫描：同类教训≥2次自动提炼为反模式"
        ],
        "on_gate_fail": [
            "emit sprint.closure.rejected 事件",
            "输出缺失项清单",
            "阻止Sprint标记完成"
        ]
    },
    "action": {
        "type": "handler",
        "handler": "sprint-closure-gate",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.sprint-closure-acceptance-001.sh"
    },
    "metadata": {
        "created": "2026-03-07",
        "source": "Day2 Gap5 closure + project-mgmt SKILL.md进化机制",
        "anti_entropy": true
    },
    "enforcement": "programmatic",
    "fullchain_status": "expanded",
    "fullchain_expanded_at": "2026-03-09T12:51:00Z",
    "fullchain_handler": "infrastructure/event-bus/handlers/sprint-closure-gate.sh",
    "handler": "skills/isc-core/handlers/sprint-closure-acceptance.js",
    "scoring_rubric": {
        "completeness": 1,
        "handler_real": 1,
        "event_bound": 0.5,
        "test_covered": 0
    },
    "north_star_indicator": "独立QA覆盖率",
    "gate_relevance": 1,
    "process_indicators": [
        "handler_execution_count",
        "gate_pass_rate"
    ],
    "layer": "quality-gate",
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 SPRINT-CLOSURE-ACCEPTANCE-001 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/sprint-closure-acceptance.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/sprint-closure-acceptance.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}