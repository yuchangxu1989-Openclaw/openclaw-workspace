{
    "id": "rule.arch-feedback-must-close-003",
    "event_type": "system.event.orphan_report",
    "description": "任何事件发布后必须有明确的消费确认。任何错误检测后必须有诊断→修复→验证的完整闭环。开环=失控。",
    "rule_name": "Feedback Must Close — 反馈必须闭环",
    "version": "1.0.0",
    "severity": "high",
    "source": "Day 1/2设计债务复盘 — AP-003架构原则，根因γ修复",
    "trigger": {
        "events": [
            "system.event.orphan_report",
            "system.event.dead_channel"
        ]
    },
    "action": {
        "type": "enforce",
        "handler": "feedback-must-close",
        "on_failure": "escalate"
    },
    "enforcement": "runtime_binding",
    "enforcement_tier": "P1_monitor",
    "schema_version": "2.0",
    "fullchain_status": "expanded",
    "handler": "skills/isc-core/handlers/arch-feedback-must-close.js",
    "verification": {
        "method": "detection_accuracy_check",
        "description": "验证检测规则 rule.arch-feedback-must-close-003 的识别准确率",
        "assertions": [
            {
                "check": "true_positive",
                "desc": "目标模式被准确识别"
            },
            {
                "check": "false_positive_low",
                "desc": "误报率在可接受范围内"
            },
            {
                "check": "alert_delivered",
                "desc": "检测到问题后告警正确发送"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/arch-feedback-must-close.js && echo 'handler_exists:pass'",
        "expected_outcome": "目标模式准确检测，误报率<5%",
        "timeout_seconds": 60,
        "on_failure": "alert"
    }
}