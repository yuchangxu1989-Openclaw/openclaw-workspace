{
    "id": "rule.n017-detection-cras-recurring-pattern-auto-resolve-017",
    "event_type": "cras.pattern.detected",
    "name": "cras_recurring_pattern_auto_resolve",
    "description": "CRAS重复模式自动解决 - CRAS-B用户洞察分析发现同一问题模式≥2次时，主动根因分析并自动解决",
    "type": "detection",
    "domain": "cognitive_reflection",
    "scope": "system-wide",
    "trigger": {
        "schedule": "0 */2 * * *",
        "command": "cd /root/.openclaw/workspace/skills/cras && node index.js --insight",
        "condition": "insight.recurring_patterns.length > 0",
        "events": [
            "cras.pattern.detected",
            "cras.recurring.issue_identified",
            "system.recurring.threshold_exceeded"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "CRAS检测到重复模式时自动触发解决方案生成并执行"
            }
        ]
    },
    "detection": {
        "source": "UserInsightHub.analyzeRecurringPatterns",
        "method": "analyze_recurring_patterns",
        "pattern_matching": {
            "fields": [
                "error_type",
                "failed_skill",
                "error_message_keyword"
            ],
            "time_window": "48h",
            "threshold": 2
        }
    },
    "governance": {
        "auto_execute": true,
        "priority": "MEDIUM",
        "risk_level": "medium"
    },
    "execution": {
        "type": "root_cause_and_fix",
        "steps": [
            {
                "order": 1,
                "action": "analyze_recurring_patterns",
                "executor": "cras/index.js",
                "method": "UserInsightHub.analyzeRecurringPatterns",
                "output": "recurring_patterns_report"
            },
            {
                "order": 2,
                "action": "auto_resolve_patterns",
                "executor": "infrastructure/pipeline/l3-pipeline.js",
                "method": "execute_auto_fix_for_patterns",
                "strategies": [
                    {
                        "pattern": "file_not_found",
                        "fix": "auto_create_file"
                    },
                    {
                        "pattern": "path_mismatch",
                        "fix": "auto_update_reference"
                    },
                    {
                        "pattern": "skill_not_loaded",
                        "fix": "trigger_skill_reload"
                    }
                ]
            },
            {
                "order": 3,
                "action": "mark_resolved",
                "executor": "cras/index.js",
                "method": "UserInsightHub.markPatternsResolved"
            }
        ]
    },
    "notification": {
        "on_complete": {
            "channel": "feishu",
            "format": "compact",
            "content": "CRAS重复模式分析完成，自动解决{resolved_count}个问题"
        }
    },
    "created_at": "2026-02-25T23:45:00Z",
    "updated_at": "2026-02-25T23:49:00Z",
    "version": "1.1.0",
    "status": "active",
    "enforcement_tier": "P1_process",
    "action": {
        "type": "handler",
        "handler": "auto-fix",
        "description": "",
        "script": "/root/.openclaw/workspace/scripts/isc-hooks/rule.n017-detection-cras-recurring-pattern-auto-resolve-017.sh"
    },
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/n017-detection-cras-recurring-pattern-auto-resolve.js",
    "verification": {
        "method": "rule_enforcement_check",
        "description": "验证规则 rule.n017-detection-cras-recurring-pattern-auto-resolve-017 的执行有效性",
        "assertions": [
            {
                "check": "handler_registered",
                "desc": "Handler已注册: skills/isc-core/handlers/n017-detection-cras-recurring-pattern-auto-resolve.js"
            },
            {
                "check": "trigger_conditions_met",
                "desc": "触发条件满足时规则被正确激活"
            },
            {
                "check": "action_executed",
                "desc": "规则激活后执行指定的动作"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/n017-detection-cras-recurring-pattern-auto-resolve.js && echo 'handler_exists:pass'",
        "expected_outcome": "规则触发条件满足时正确执行预定义动作",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}