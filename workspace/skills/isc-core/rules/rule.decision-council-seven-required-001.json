{
  "type": "decision-rule",
  "id": "R006",
  "name": "lingxiaoge_tribunal_required",
  "description": "关键决策必经七人议会审议 - 所有新规则、订阅变更、流水线模块更新",
  "condition": "impact > 3 OR priority >= 9 OR type IN (security, architecture, new_skill, merge_skill, critical_rule, new_rule, subscription_change, pipeline_update)",
  "threshold": {
    "impact": 3,
    "priority": 9,
    "types": [
      "security",
      "architecture",
      "new_skill",
      "merge_skill",
      "critical_rule",
      "new_rule",
      "subscription_change",
      "pipeline_update"
    ],
    "approval_ratio": 0.6
  },
  "priority": 10,
  "action": {
    "type": "monitor",
    "handler": "lingxiaoge-tribunal-dispatcher",
    "on_failure": "warn",
    "description": "影响等级>3或类型为关键决策时，自动触发凌霄阁7人议会审议"
  },
  "integration": {
    "script": "/root/.openclaw/workspace/skills/isc-core/integrations/council_integration.py",
    "council_script": "/root/.openclaw/workspace/skills/council-of-seven/council.py",
    "decisions_dir": "/root/.openclaw/workspace/skills/isc-core/council-decisions"
  },
  "category": "governance",
  "version": "1.1.0",
  "created_at": "2026-02-23T18:20:00Z",
  "updated_at": "2026-02-23T18:25:00Z",
  "status": "active",
  "trigger": {
    "events": {
      "L1": [
        "isc:rule:matched",
        "isc:category:governance"
      ]
    },
    "condition": "impact > 3 OR priority >= 9 OR type IN (security, architecture, new_skill, merge_skill, critical_rule, new_rule, subscription_change, pipeline_update)"
  },
  "enforcement_tier": "P0_gate",
  "schema_version": "2.0",
  "migrated_at": "2026-03-05T08:01:40+08:00"
}