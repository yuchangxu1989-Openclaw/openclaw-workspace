{
    "id": "rule.isc-skill-usage-protocol-001",
    "event_type": "isc.rule.matched",
    "name": "isc_skill_usage_protocol",
    "description": "技能使用协议 - 使用任何技能前必须先读取SKILL.md确认用法，禁止凭猜测调用",
    "domain": "standards",
    "type": "rule",
    "scope": "skill",
    "rationale": "防止因技能语言、入口文件不一致导致调用失败",
    "enforcement": {
        "before_use": "必须读取SKILL.md",
        "check_items": [
            "语言",
            "入口文件",
            "使用方法"
        ],
        "violation_action": "拒绝执行并提示查看SKILL.md"
    },
    "governance": {
        "auto_execute": true,
        "councilRequired": false
    },
    "created_at": "2026-02-25T15:13:00+08:00",
    "version": "1.0.0",
    "trigger": {
        "events": [
            "isc.rule.matched",
            "isc.category.matched"
        ],
        "actions": [
            {
                "type": "log",
                "level": "info"
            }
        ],
        "event": "isc.rule.matched"
    },
    "enforcement_tier": "P0_gate",
    "action": {
        "type": "check",
        "handler": "document-structure-check"
    },
    "handler": "skills/isc-core/handlers/isc-skill-usage-protocol-001.js",
    "verification": {
        "method": "gate_enforcement_check",
        "description": "验证门禁规则 rule.isc-skill-usage-protocol-001 的拦截能力",
        "assertions": [
            {
                "check": "handler_exists",
                "desc": "Handler文件存在且可执行: skills/isc-core/handlers/isc-skill-usage-protocol-001.js"
            },
            {
                "check": "violation_blocked",
                "desc": "违规操作被成功拦截并记录日志"
            },
            {
                "check": "compliant_passes",
                "desc": "合规操作正常通过不被误拦"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/isc-skill-usage-protocol-001.js && echo 'handler_exists:pass'",
        "expected_outcome": "违规操作100%被拦截，合规操作0%误拦",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}