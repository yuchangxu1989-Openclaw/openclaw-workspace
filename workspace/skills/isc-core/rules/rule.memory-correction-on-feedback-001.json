{
    "id": "memory-correction-on-feedback-001",
    "event_type": "user.feedback.correction",
    "name": "用户纠偏触发记忆反查与修正",
    "description": "用户纠偏时自动反查MEMORY.md中的矛盾记忆并修正",
    "priority": "P0",
    "trigger": {
        "event": "user.feedback.correction",
        "events": [
            "isc.rule.memory.correction.on.feedback.001",
            "user.feedback.correction"
        ]
    },
    "action": {
        "handler": "scripts/isc-hooks/rule.memory-correction-on-feedback-001.sh"
    },
    "tags": [
        "memory",
        "self-correction",
        "anti-entropy"
    ],
    "handler": "skills/isc-core/handlers/memory-correction-on-feedback.js",
    "verification": {
        "method": "knowledge_integrity_check",
        "description": "验证知识规则 memory-correction-on-feedback-001 的存储和检索正确性",
        "assertions": [
            {
                "check": "data_persisted",
                "desc": "知识/记忆数据被正确持久化"
            },
            {
                "check": "retrieval_accurate",
                "desc": "检索结果与查询语义匹配"
            },
            {
                "check": "no_data_loss",
                "desc": "写入后读取数据无丢失"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/memory-correction-on-feedback.js && echo 'handler_exists:pass'",
        "expected_outcome": "知识正确持久化且可准确检索",
        "timeout_seconds": 120,
        "on_failure": "log"
    }
}