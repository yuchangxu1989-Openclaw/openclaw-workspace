{
    "id": "rule.intent-aeo-quality-gate-001",
    "event_type": "event.system.modified",
    "description": "意图识别系统的任何变更（新增意图类型、修改识别逻辑、更换模型）必须通过AEO评测准出：黄金评测集自动化测试通过 + Badcase主动根因分析完成。评测链必须以LLM语义意图识别为主判断链，关键词/正则仅可作为辅助交叉匹配信号，未通过不得上线。",
    "rule_name": "意图识别AEO准出门禁",
    "version": "1.1.0",
    "severity": "critical",
    "trigger": {
        "events": [
            "event.system.modified",
            "event.type.created"
        ],
        "actions": [
            {
                "type": "auto_trigger",
                "description": "触发AEO自动化评测 → 生成报告 → Badcase根因分析 → 通过后方可生效"
            }
        ],
        "event": "event.system.modified"
    },
    "action": {
        "type": "script",
        "handler": "eval-quality-check",
        "script": "scripts/isc-hooks/rule.intent-aeo-quality-gate-001.sh"
    },
    "enforcement_tier": "P1_process",
    "enforcement": "programmatic",
    "handler": "skills/isc-core/handlers/intent-aeo-quality-gate.js",
    "fullchain_status": "expanded",
    "verification": {
        "method": "quality_gate_check",
        "description": "验证质量规则 rule.intent-aeo-quality-gate-001 的检查能力",
        "assertions": [
            {
                "check": "quality_criteria_defined",
                "desc": "质量标准有明确的判定条件"
            },
            {
                "check": "pass_fail_distinguishable",
                "desc": "合格与不合格的产出可被准确区分"
            },
            {
                "check": "feedback_actionable",
                "desc": "不合格时反馈的问题可被执行者修复"
            }
        ],
        "test_command": "test -f /root/.openclaw/workspace/skills/isc-core/handlers/intent-aeo-quality-gate.js && echo 'handler_exists:pass'",
        "expected_outcome": "低质量产出被拦截，高质量产出通过",
        "timeout_seconds": 30,
        "on_failure": "block_and_alert"
    }
}