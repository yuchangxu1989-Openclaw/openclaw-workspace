    {
      "id": "case_api_001",
      "name": "API接口性能测试",
      "description": "验证API接口在高并发下的响应时间和稳定性",
      "category": "performance",
      "domain": "api",
      "tags": [
        "api",
        "performance",
        "load",
        "stress"
      ],
      "input": {
        "endpoint": "/api/v1/users",
        "method": "GET",
        "concurrency": 100,
        "duration": 60
      },
      "expected": {
        "avgResponseTime": "< 200ms",
        "p99ResponseTime": "< 500ms",
        "errorRate": "< 1%"
      },
      "assertions": [
        {
          "check": "p95_latency < 300",
          "description": "95%请求响应时间小于300ms"
        },
        {
          "check": "error_rate < 0.01",
          "description": "错误率小于1%"
        }
      ],
      "scoring_rubric": {
        "scale": "1-10",
        "criteria": [
          {
            "score": "9-10",
            "condition": "P95<300ms，错误率<0.1%，资源利用率合理，无内存泄漏"
          },
          {
            "score": "7-8",
            "condition": "P95<500ms，错误率<1%，偶有资源波动"
          },
          {
            "score": "4-6",
            "condition": "P95>500ms或错误率>1%，存在性能瓶颈"
          },
          {
            "score": "1-3",
            "condition": "严重性能问题，超时频繁或资源耗尽"
          }
        ]
      },
