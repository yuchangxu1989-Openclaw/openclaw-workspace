    {
      "id": "case_api_002",
      "name": "API速率限制测试",
      "description": "验证API在超过请求频率限制时返回429状态码",
      "category": "function",
      "domain": "api",
      "tags": [
        "api",
        "rate-limit",
        "security",
        "throttling"
      ],
      "input": {
        "endpoint": "/api/v1/data",
        "requests": 150,
        "perSecond": 1
      },
      "expected": {
        "rateLimited": true,
        "retryAfter": 60
      },
      "assertions": [
        {
          "check": "response.status === 429",
          "description": "返回HTTP 429 Too Many Requests"
        },
        {
          "check": "response.headers['x-ratelimit-remaining'] === '0'",
          "description": "Rate limit header归零"
        }
      ],
      "scoring_rubric": {
        "scale": "1-10",
        "criteria": [
          {
            "score": "9-10",
            "condition": "限流策略精确生效，429状态码正确返回，Retry-After头准确"
          },
          {
            "score": "7-8",
            "condition": "限流基本生效，但边界值处理不够精确"
          },
          {
            "score": "4-6",
            "condition": "限流部分生效，存在绕过可能或误限正常请求"
          },
          {
            "score": "1-3",
            "condition": "限流机制失效或严重误判"
          }
        ]
      },
