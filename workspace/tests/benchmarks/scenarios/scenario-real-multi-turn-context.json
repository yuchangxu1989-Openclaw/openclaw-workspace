{
  "id": "scenario-real-multi-turn-context",
  "name": "多轮上下文依赖：系统崩溃调查",
  "domain": "development",
  "description": "用户报告系统断联，需要Agent基于第1轮的断联信息在第3轮做根因分析",
  "source": "real-conversation",
  "source_date": "2026-02-26",
  "original_text": "12:30断联了...13:55重启服务器...会话文件2.8MB导致处理延迟→飞书心跳超时→WebSocket断开",
  "complexity": {
    "turns": "multi-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "system-interrupt",
    "domain_cross": "cross-domain"
  },
  "complexity_tags": ["multi-turn", "context-dependent", "system-interrupt", "cross-domain", "root-cause-analysis"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "系统好像断联了，从12:30开始就没反应了" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "我13:55手动重启了服务器，现在恢复了" }
    },
    { "expect": "intent_detected", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "帮我分析下根因，之前那个2.8MB的会话文件是不是问题" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
