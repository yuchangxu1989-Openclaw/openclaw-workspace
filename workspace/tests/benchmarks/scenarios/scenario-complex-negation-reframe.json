{
  "id": "scenario-complex-negation-reframe",
  "name": "否定重构：不是这个意思",
  "domain": "development",
  "description": "用户否定Agent的理解并用完全不同的方式重新表述需求",
  "source": "synthetic",
  "reference": "correction handling pattern",
  "complexity": {
    "turns": "multi-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "user-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["negation", "correction", "reframe", "context-dependent"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "帮我优化一下数据库查询" }
    },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "不是优化SQL，我是说整个数据访问层的架构要改，现在读写不分离扛不住了" }
    },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
