{
  "id": "scenario-real-bug-mid-execution",
  "name": "执行中发现Bug：apiKey配置灾难",
  "domain": "development",
  "description": "执行多个子Agent任务过程中发现配置bug导致全部失败",
  "source": "real-conversation",
  "source_date": "2026-03-01",
  "original_text": "apiKey(string)改为apiKeys(array)→OpenClaw不认→所有子Agent全部空壳失败",
  "complexity": {
    "turns": "multi-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "system-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["system-interrupt", "bug-discovery", "context-dependent", "cascading-failure", "recovery"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "为什么spawn的3个子Agent全部失败了？日志显示empty history" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "是不是apiKey配置的问题？我之前改成了数组格式" }
    },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
