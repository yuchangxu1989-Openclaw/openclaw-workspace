{
  "id": "scenario-cras-engineering-defect",
  "name": "CRAS工程缺陷模式识别",
  "domain": "knowledge",
  "description": "识别工程代码中反复出现的缺陷模式",
  "steps": [
    { "action": "emit", "event": "user.message", "payload": { "text": "我们项目最近三个月反复出现类似的bug，都是在异步回调里忘了错误处理，帮我分析一下这个缺陷模式怎么根治" } },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "cras*" },
    { "expect": "result", "has_output": true }
  ]
}
