{
  "id": "scenario-complex-knowledge-graph",
  "name": "知识图谱查询：技能依赖关系",
  "domain": "knowledge",
  "description": "需要理解实体关系并做链式推理的查询",
  "source": "synthetic",
  "reference": "AgentBench knowledge graph task",
  "complexity": {
    "turns": "single-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "no-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["knowledge-reasoning", "relationship-query", "chain-reasoning"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "CRAS依赖事件总线，事件总线依赖JSONL存储，DTO也依赖事件总线。如果我改了事件总线的API，影响范围是什么？" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
