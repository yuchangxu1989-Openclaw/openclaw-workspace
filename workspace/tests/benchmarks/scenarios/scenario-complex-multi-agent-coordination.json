{
  "id": "scenario-complex-multi-agent-coordination",
  "name": "多Agent协调：架构→开发→测试流水线",
  "domain": "development",
  "description": "需要编排多个角色Agent按序执行：架构师设计→开发实现→质量测试",
  "source": "synthetic",
  "reference": "CrewAI/MetaGPT multi-agent workflow",
  "complexity": {
    "turns": "single-turn",
    "intent": "single-intent",
    "context": "context-free",
    "interrupt": "no-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["multi-agent", "sequential-pipeline", "role-based-execution"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "用凌霄阁流程审查这个方案：先让架构师出设计，工程师验证可落地性，质量分析师评分，最后给我终审" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
