{
  "id": "scenario-complex-incremental-correction",
  "name": "递进修正：3轮逐步收窄范围",
  "domain": "development",
  "description": "用户通过3轮对话逐步缩小问题范围和调整需求",
  "source": "synthetic",
  "reference": "progressive refinement dialogue pattern",
  "complexity": {
    "turns": "multi-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "no-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["multi-turn", "progressive-refinement", "context-dependent", "scope-narrowing"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "系统性能有点问题" }
    },
    { "expect": "intent_detected", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "主要是API响应慢，特别是查询接口" }
    },
    { "expect": "intent_detected", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "查了下日志，是N+1查询问题，帮我改成批量加载" }
    },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
