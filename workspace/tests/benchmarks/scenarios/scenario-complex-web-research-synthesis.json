{
  "id": "scenario-complex-web-research-synthesis",
  "name": "网络研究+综合分析：竞品调研",
  "domain": "analysis",
  "description": "需要搜索多个信息源、综合分析并输出结构化结论",
  "source": "synthetic",
  "reference": "web browsing + analysis multi-step pattern",
  "complexity": {
    "turns": "single-turn",
    "intent": "multi-intent",
    "context": "context-free",
    "interrupt": "no-interrupt",
    "domain_cross": "cross-domain"
  },
  "complexity_tags": ["multi-intent", "cross-domain", "web-research", "synthesis", "structured-output"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "调研一下AutoGPT、CrewAI、MetaGPT和OpenDevin这四个竞品的最新进展，按五看三定方法论给我一个对比分析，重点关注多Agent协作架构和评测方法" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
