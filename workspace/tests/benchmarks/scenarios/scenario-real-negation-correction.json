{
  "id": "scenario-real-negation-correction",
  "name": "否定/修正：架构方案被打回",
  "domain": "development",
  "description": "用户对Agent产出的方案不满意，要求按新的思路重做",
  "source": "real-conversation",
  "source_date": "2026-03-04",
  "original_text": "8.5是你的标准不是我的标准。要做就做全球最顶级AI。继续改到断层式领先",
  "complexity": {
    "turns": "multi-turn",
    "intent": "single-intent",
    "context": "context-dependent",
    "interrupt": "user-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["negation", "correction", "context-dependent", "user-interrupt", "quality-escalation"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "这个v4.1方案评分7.08，不够好" }
    },
    { "expect": "intent_detected", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "不是这个标准，8.5是你的底线不是我的。要做就做全球最顶级的，继续改" }
    },
    { "expect": "intent_detected", "intent_category": "IC1", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
