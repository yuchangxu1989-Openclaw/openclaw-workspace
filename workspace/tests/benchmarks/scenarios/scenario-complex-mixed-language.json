{
  "id": "scenario-complex-mixed-language",
  "name": "中英混杂：技术讨论带专业术语",
  "domain": "development",
  "description": "用户在中文语境中频繁使用英文技术术语，需要正确理解语义",
  "source": "synthetic",
  "reference": "bilingual code-switching in technical communication",
  "complexity": {
    "turns": "single-turn",
    "intent": "single-intent",
    "context": "context-free",
    "interrupt": "no-interrupt",
    "domain_cross": "single-domain"
  },
  "complexity_tags": ["mixed-language", "technical-jargon", "code-switching"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "把event bus的consumer改成at-least-once delivery，加个dead letter queue处理poison message，用exponential backoff做retry" }
    },
    { "expect": "intent_detected", "intent_category": "IC2", "timeout_ms": 5000 },
    { "expect": "rule_matched", "min_rules": 1 },
    { "expect": "dispatched", "handler_pattern": "*" },
    { "expect": "result", "has_output": true }
  ]
}
