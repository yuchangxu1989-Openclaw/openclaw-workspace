{
  "id": "scenario-complex-mid-conversation-switch",
  "name": "会话中途切换：技术突转天气",
  "domain": "knowledge",
  "description": "正在深入讨论技术问题时突然切换到完全无关的日常话题",
  "source": "synthetic",
  "reference": "intent switching robustness test",
  "complexity": {
    "turns": "multi-turn",
    "intent": "intent-switch",
    "context": "context-conflict",
    "interrupt": "user-interrupt",
    "domain_cross": "cross-domain"
  },
  "complexity_tags": ["intent-switch", "context-conflict", "user-interrupt", "domain-jump"],
  "steps": [
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "事件总线的消费者限流策略应该怎么设计？考虑高并发场景" }
    },
    { "expect": "intent_detected", "intent_category": "IC3", "timeout_ms": 5000 },
    {
      "action": "emit",
      "event": "user.message",
      "payload": { "text": "算了先不聊这个了，今天北京天气怎么样？我下午要出门" }
    },
    { "expect": "intent_detected", "timeout_ms": 5000 },
    { "expect": "rule_matched" },
    { "expect": "result", "has_output": true }
  ]
}
