    "eval.weather.001": {
      "id": "eval.weather.001",
      "name": "天气技能黄金标准评测集",
      "targetSkill": "weather",
      "track": "functional-quality",
      "standard": "golden",
      "location": {
        "type": "inline"
      },
      "metadata": {
        "description": "天气查询技能核心功能路径黄金标准",
        "author": "aeo",
        "createdAt": "2026-02-26T20:00:00+08:00",
        "updatedAt": "2026-02-26T20:00:00+08:00",
        "version": "1.0.0",
        "testCaseCount": 5
      },
      "testCases": [
        {
          "id": "tc-001",
          "name": "查询北京今天天气",
          "input": { "city": "北京", "date": "today" },
          "expected": { "contains": ["温度", "天气"] }
        },
        {
          "id": "tc-002",
          "name": "查询上海明天天气",
          "input": { "city": "上海", "date": "tomorrow" },
          "expected": { "contains": ["温度", "天气"] }
        },
        {
          "id": "tc-003",
          "name": "无效城市处理",
          "input": { "city": "不存在的城市", "date": "today" },
          "expected": { "error": true, "message": "城市不存在" }
        },
        {
          "id": "tc-004",
          "name": "查询纽约天气（国际）",
          "input": { "city": "New York", "date": "today" },
          "expected": { "contains": ["temperature", "weather"] }
        },
        {
          "id": "tc-005",
          "name": "并发请求处理",
          "input": { "city": "北京", "date": "today", "concurrent": 10 },
          "expected": { "responseTime": { "max": 2000 } }
        }
      ],
      "dimensions": [
        { "name": "accuracy", "weight": 0.35, "threshold": 0.95 },
        { "name": "responseTime", "weight": 0.25, "threshold": 0.9 },
        { "name": "errorRate", "weight": 0.25, "threshold": 0.95 },
        { "name": "compatibility", "weight": 0.1, "threshold": 0.85 },
        { "name": "stability", "weight": 0.05, "threshold": 0.9 }
      ],
      "dtoMapping": {
        "subscriptionId": "N028",
        "autoTrigger": true
      }
    },
    
